      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Manrope:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --void-black: #050510;\n    --dark-ultramarine: #120A8F;\n    --violet: #8A2BE2;\n    --cyan: #00FFFF;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--void-black);\n    color: #ffffff;\n    font-family: 'Manrope', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, h4, .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .aurora {\n    background: radial-gradient(circle at 20% 30%, var(--dark-ultramarine) 0%, transparent 40%),\n                radial-gradient(circle at 80% 70%, var(--violet) 0%, transparent 40%),\n                radial-gradient(circle at 50% 50%, #0a0a20 0%, transparent 60%);\n    background-size: 200% 200%;\n    position: fixed;\n    inset: 0;\n    z-index: -1;\n  }\n\n  .btn-submit {\n    background: linear-gradient(135deg, var(--violet), var(--dark-ultramarine));\n    border: 1px solid var(--cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);\n  }\n\n  .contact-pill {\n    background: rgba(255, 255, 255, 0.05);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.1);\n    transition: border-color 0.3s ease;\n  }\n\n  input, textarea {\n    background: rgba(255, 255, 255, 0.05) !important;\n    border: 1px solid rgba(255, 255, 255, 0.1) !important;\n    border-radius: 12px !important;\n    color: white !important;\n    outline: none !important;\n  }\n\n  input:focus, textarea:focus {\n    border-color: var(--cyan) !important;\n    box-shadow: 0 0 0 1px var(--cyan) !important;\n  }\n</style>\n\n<div class=\"aurora\" data-kid=\"1\"></div>\n\n<div id=\"smooth-wrapper\" data-kid=\"2\">\n  <div id=\"smooth-content\" data-kid=\"3\">\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center backdrop-blur-md border-b border-white/5\" data-kid=\"4\">\n      <div class=\"flex items-center gap-2\" data-kid=\"5\">\n        <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"6\"></div>\n        <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"7\">YUG AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/70\" data-kid=\"8\">\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"9\">Services</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"10\">Industries</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"11\">Portfolio</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"12\">About</a>\n        <a href=\"#\" class=\"px-5 py-2.5 glass text-white hover:border-cyan-400/50 transition-all border-cyan-400/20\" data-kid=\"13\">Home</a>\n      </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-[70vh] flex flex-col items-center justify-center pt-32 pb-20 px-6 text-center\" data-kid=\"14\">\n      <div class=\"container mx-auto max-w-4xl space-y-8\" data-kid=\"15\">\n        <div class=\"inline-flex items-center gap-3 px-4 py-2 glass border-cyan-400/20 text-cyan-400 text-xs font-bold uppercase tracking-widest mx-auto\" data-kid=\"16\">\n          <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"17\"></span>\n          Connect with our team\n        </div>\n        <h1 class=\"hero-title text-6xl lg:text-9xl font-outfit font-bold leading-[0.9] tracking-tighter\" data-kid=\"18\">\n          Let's build <br data-kid=\"19\"> better AI <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-violet-500\" data-kid=\"20\">together.</span>\n        </h1>\n        <p class=\"hero-desc text-xl text-white/60 max-w-2xl mx-auto leading-relaxed\" data-kid=\"21\">\n          Book a discovery call, request a pilot proposal, or ask us anything. We typically respond within 24 hours.\n        </p>\n      </div>\n    </section>\n\n    \n    <section class=\"py-20 px-6 overflow-hidden\" data-kid=\"22\">\n      <div class=\"container mx-auto\" data-kid=\"23\">\n        <div class=\"flex flex-wrap justify-center gap-6 relative h-[300px] items-center\" data-kid=\"24\">\n          \n          <a href=\"https://calendly.com/yug-ai\" target=\"_blank\" class=\"contact-pill floating-island px-8 py-5 rounded-full flex items-center gap-4 group absolute top-0 left-[15%]\" data-kid=\"25\">\n            <div class=\"w-10 h-10 rounded-full bg-cyan-400/20 flex items-center justify-center text-cyan-400\" data-kid=\"26\">\n              <i class=\"ti ti-calendar text-xl\" data-kid=\"27\"></i>\n            </div>\n            <div class=\"text-left\" data-kid=\"28\">\n              <p class=\"text-[10px] uppercase font-bold text-cyan-400 tracking-widest\" data-kid=\"29\">Calendly</p>\n              <p class=\"text-sm font-bold\" data-kid=\"30\">Book a Discovery Call</p>\n            </div>\n          </a>\n\n          <a href=\"mailto:hello@yugai.live\" class=\"contact-pill floating-island px-8 py-5 rounded-full flex items-center gap-4 group absolute top-20 right-[20%]\" data-kid=\"31\">\n            <div class=\"w-10 h-10 rounded-full bg-violet-400/20 flex items-center justify-center text-violet-400\" data-kid=\"32\">\n              <i class=\"ti ti-mail text-xl\" data-kid=\"33\"></i>\n            </div>\n            <div class=\"text-left\" data-kid=\"34\">\n              <p class=\"text-[10px] uppercase font-bold text-violet-400 tracking-widest\" data-kid=\"35\">Email</p>\n              <p class=\"text-sm font-bold\" data-kid=\"36\">hello@yugai.live</p>\n            </div>\n          </a>\n\n          <a href=\"https://wa.me/911234567890\" target=\"_blank\" class=\"contact-pill floating-island px-8 py-5 rounded-full flex items-center gap-4 group absolute bottom-0 left-[35%]\" data-kid=\"37\">\n            <div class=\"w-10 h-10 rounded-full bg-cyan-400/20 flex items-center justify-center text-cyan-400\" data-kid=\"38\">\n              <i class=\"ti ti-brand-whatsapp text-xl\" data-kid=\"39\"></i>\n            </div>\n            <div class=\"text-left\" data-kid=\"40\">\n              <p class=\"text-[10px] uppercase font-bold text-cyan-400 tracking-widest\" data-kid=\"41\">WhatsApp</p>\n              <p class=\"text-sm font-bold\" data-kid=\"42\">Chat with the team</p>\n            </div>\n          </a>\n\n          <div class=\"contact-pill floating-island px-8 py-5 rounded-full flex items-center gap-4 absolute bottom-10 right-[10%]\" data-kid=\"43\">\n            <div class=\"w-10 h-10 rounded-full bg-violet-400/20 flex items-center justify-center text-violet-400\" data-kid=\"44\">\n              <i class=\"ti ti-file-description text-xl\" data-kid=\"45\"></i>\n            </div>\n            <div class=\"text-left\" data-kid=\"46\">\n              <p class=\"text-[10px] uppercase font-bold text-violet-400 tracking-widest\" data-kid=\"47\">Proposal</p>\n              <p class=\"text-sm font-bold\" data-kid=\"48\">Request Pilot Proposal</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"form-section\" class=\"py-32 px-6\" data-kid=\"49\">\n      <div class=\"container mx-auto\" data-kid=\"50\">\n        <div class=\"form-island glass p-10 lg:p-20 max-w-5xl mx-auto space-y-12\" data-kid=\"51\">\n          <div class=\"space-y-4 text-center lg:text-left\" data-kid=\"52\">\n            <h2 class=\"text-4xl lg:text-6xl font-outfit font-bold\" data-kid=\"53\">Send a <span class=\"text-violet-400\" data-kid=\"54\">message.</span></h2>\n            <p class=\"text-white/50 text-lg\" data-kid=\"55\">Tell us about your project and we'll get back to you with a tailored approach.</p>\n          </div>\n\n          <form class=\"grid grid-cols-1 md:grid-cols-2 gap-8\" data-kid=\"56\">\n            <div class=\"space-y-2\" data-kid=\"57\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-white/40 ml-1\" data-kid=\"58\">Full Name</label>\n              <input type=\"text\" placeholder=\"Krishna Bajpai\" class=\"w-full px-5 py-4\" data-kid=\"59\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"60\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-white/40 ml-1\" data-kid=\"61\">Email Address</label>\n              <input type=\"email\" placeholder=\"name@company.com\" class=\"w-full px-5 py-4\" data-kid=\"62\">\n            </div>\n            <div class=\"space-y-2 md:col-span-2\" data-kid=\"63\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-white/40 ml-1\" data-kid=\"64\">Company / Project Website</label>\n              <input type=\"text\" placeholder=\"yugai.live\" class=\"w-full px-5 py-4\" data-kid=\"65\">\n            </div>\n            <div class=\"space-y-2 md:col-span-2\" data-kid=\"66\">\n              <label class=\"text-xs font-bold uppercase tracking-widest text-white/40 ml-1\" data-kid=\"67\">How can we help?</label>\n              <textarea rows=\"5\" placeholder=\"Describe your data annotation or model evaluation needs...\" class=\"w-full px-5 py-4 resize-none\" data-kid=\"68\"></textarea>\n            </div>\n            <div class=\"md:col-span-2 pt-4 flex flex-col lg:flex-row items-center justify-between gap-8\" data-kid=\"69\">\n              <div class=\"flex items-center gap-4 text-white/40 text-sm\" data-kid=\"70\">\n                <i class=\"ti ti-info-circle text-lg text-cyan-400\" data-kid=\"71\"></i>\n                Typically responds in under 24 hours\n              </div>\n              <button type=\"submit\" class=\"btn-submit px-12 py-5 rounded-full font-bold text-xl w-full lg:w-auto flex items-center justify-center gap-3 group\" data-kid=\"72\">\n                Send Message\n                <i class=\"ti ti-send group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform\" data-kid=\"73\"></i>\n              </button>\n            </div>\n          </form>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"py-20 border-t border-white/5 bg-[#030308]\" data-kid=\"74\">\n      <div class=\"container mx-auto px-6 text-center space-y-8\" data-kid=\"75\">\n        <div class=\"flex items-center justify-center gap-2\" data-kid=\"76\">\n          <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"77\"></div>\n          <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"78\">YUG AI</span>\n        </div>\n        <p class=\"text-white/40 max-w-sm mx-auto leading-relaxed\" data-kid=\"79\">Precision human intelligence for modern AI teams. Built for safety, accuracy, and enterprise-scale operations.</p>\n        <div class=\"pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-[0.2em] text-white/20\" data-kid=\"80\">\n          <span data-kid=\"81\">© 2026 YUG AI OPERATIONS</span>\n          <div class=\"flex gap-8\" data-kid=\"82\">\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"83\">Twitter</a>\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"84\">LinkedIn</a>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"85\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"86\"></script>\n<script type=\"module\" data-kid=\"87\">\n  import { animate, inView, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate, stagger as animeStagger } from 'https://esm.sh/animejs@4'\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Smooth Scrolling\n  const lenis = new Lenis()\n  lenis.on('scroll', ScrollTrigger.update)\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000)\n  })\n  gsap.ticker.lagSmoothing(0)\n\n  // Aurora Gradient Animation\n  animeAnimate('.aurora', {\n    backgroundPosition: ['0% 0%', '100% 50%', '0% 100%', '0% 0%'],\n    duration: 30000,\n    loop: true,\n    ease: 'linear'\n  });\n\n  // Floating Islands Loop\n  document.querySelectorAll('.floating-island').forEach((el, i) => {\n    animeAnimate(el, {\n      y: [-10, 10],\n      duration: 3000 + i * 500,\n      alternate: true,\n      loop: true,\n      ease: 'inOut(2)'\n    });\n  });\n\n  // Entrance Animations\n  gsap.from('.hero-title', {\n    autoAlpha: 0,\n    y: 50,\n    duration: 1.2,\n    ease: 'power4.out'\n  });\n\n  gsap.from('.hero-desc', {\n    autoAlpha: 0,\n    y: 30,\n    duration: 1,\n    delay: 0.3,\n    ease: 'power3.out'\n  });\n\n  // Form Island Reveal (Pinned Scrub)\n  gsap.from('.form-island', {\n    scrollTrigger: {\n      trigger: '#form-section',\n      start: 'top 80%',\n      end: 'top 20%',\n      scrub: 1\n    },\n    autoAlpha: 0,\n    scale: 0.9,\n    y: 100,\n    rotationX: 5\n  });\n\n  // Magnetic Effect for Buttons & Pills\n  const applyMagneticEffect = (elements) => {\n    document.querySelectorAll(elements).forEach(el => {\n      el.addEventListener('mousemove', (e) => {\n        const rect = el.getBoundingClientRect();\n        const x = e.clientX - rect.left - rect.width / 2;\n        const y = e.clientY - rect.top - rect.height / 2;\n        gsap.to(el, {\n          x: x * 0.3,\n          y: y * 0.3,\n          duration: 0.4,\n          ease: 'power2.out'\n        });\n      });\n      el.addEventListener('mouseleave', () => {\n        gsap.to(el, {\n          x: 0,\n          y: 0,\n          duration: 0.6,\n          ease: 'elastic.out(1, 0.3)'\n        });\n      });\n    });\n  };\n\n  applyMagneticEffect('.btn-submit');\n  applyMagneticEffect('.contact-pill');\n\n</script>",
