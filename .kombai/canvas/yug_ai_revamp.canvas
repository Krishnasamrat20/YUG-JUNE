      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;600;700&family=Inter:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --bg: #0A0A0F;\n    --card: #1A1A2E;\n    --cyan: #00F0FF;\n    --magenta: #FF00FF;\n    --text-primary: #FFFFFF;\n    --text-secondary: #A0A0B0;\n  }\n\n  body {\n    background-color: var(--bg);\n    color: var(--text-primary);\n    font-family: 'Inter', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  .font-heading { font-family: 'Space Grotesk', sans-serif; }\n  \n  .glass {\n    background: rgba(26, 26, 46, 0.6);\n    backdrop-filter: blur(12px);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n  }\n\n  .neon-cyan-glow {\n    box-shadow: 0 0 15px rgba(0, 240, 255, 0.3);\n  }\n\n  .neon-magenta-glow {\n    box-shadow: 0 0 15px rgba(255, 0, 255, 0.3);\n  }\n\n  .neon-inset-cyan {\n    box-shadow: 0 0 15px rgba(0, 240, 255, 0.2), inset 0 0 20px rgba(0, 240, 255, 0.05);\n  }\n\n  @keyframes marquee {\n    from { transform: translateX(0); }\n    to { transform: translateX(-50%); }\n  }\n\n  .animate-marquee {\n    display: flex;\n    width: max-content;\n    animation: marquee 30s linear infinite;\n  }\n\n  .animate-marquee:hover {\n    animation-play-state: paused;\n  }\n\n  .s-curve-line {\n    position: absolute;\n    left: 50%;\n    top: 0;\n    bottom: 0;\n    width: 2px;\n    background: linear-gradient(to bottom, transparent, var(--cyan), var(--magenta), transparent);\n    transform: translateX(-50%);\n    filter: blur(1px);\n  }\n</style>\n\n\n<nav class=\"fixed top-0 left-0 w-full z-50 px-6 py-4\" data-kid=\"1\">\n  <div class=\"max-w-7xl mx-auto flex items-center justify-between glass rounded-2xl px-8 py-3\" data-kid=\"2\">\n    <div class=\"flex items-center gap-2\" data-kid=\"3\">\n      <div class=\"w-8 h-8 rounded-lg bg-[linear-gradient(135deg,var(--cyan),var(--magenta))] flex items-center justify-center\" data-kid=\"4\">\n        <span class=\"text-black font-bold text-xs\" data-kid=\"5\">YUG</span>\n      </div>\n      <span class=\"font-heading font-bold text-xl tracking-tight\" data-kid=\"6\">YUG AI</span>\n    </div>\n    <div class=\"hidden md:flex items-center gap-8 text-sm font-medium\" data-kid=\"7\">\n      <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"8\">Services</a>\n      <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"9\">Industries</a>\n      <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"10\">Workflow</a>\n      <a href=\"#\" class=\"hover:text-[var(--cyan)] transition-colors\" data-kid=\"11\">Safety</a>\n    </div>\n    <button class=\"btn-magnetic glass px-6 py-2 rounded-xl text-sm font-bold border-[var(--cyan)]/30 hover:border-[var(--cyan)] transition-all\" data-kid=\"12\">\n      Start Pilot\n    </button>\n  </div>\n</nav>\n\n\n<section class=\"pt-32 pb-20 px-6 relative overflow-hidden\" data-kid=\"13\">\n  <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-full h-full -z-10 opacity-20\" data-kid=\"14\">\n    <div class=\"absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[800px] bg-[radial-gradient(circle,var(--cyan)_0%,transparent_70%)] blur-[120px]\" data-kid=\"15\"></div>\n  </div>\n\n  <div class=\"max-w-7xl mx-auto grid grid-cols-12 gap-6\" data-kid=\"16\">\n    \n    <div class=\"col-span-12 lg:col-span-8 glass rounded-3xl p-10 lg:p-16 relative overflow-hidden flex flex-col justify-end min-h-[500px] reveal-up\" data-kid=\"17\">\n      <div class=\"absolute top-0 right-0 w-full h-full -z-10\" data-kid=\"18\">\n        <video src=\"https://videos.pexels.com/video-files/4990233/4990233-hd_1280_720_30fps.mp4\" poster=\"https://images.pexels.com/videos/4990233/pexels-photo-4990233.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-full object-cover opacity-30\" data-kid=\"19\"></video>\n      </div>\n      <div class=\"relative z-10\" data-kid=\"20\">\n        <div class=\"flex items-center gap-2 mb-6\" data-kid=\"21\">\n          <span class=\"w-2 h-2 rounded-full bg-[var(--cyan)] shadow-[0_0_10px_var(--cyan)]\" data-kid=\"22\"></span>\n          <span class=\"text-xs font-bold tracking-widest uppercase text-[var(--cyan)]\" data-kid=\"23\">Enterprise AI Operations</span>\n        </div>\n        <h1 class=\"font-heading text-5xl lg:text-7xl font-bold leading-[1.1] mb-8\" data-kid=\"24\">\n          Human Intelligence<br data-kid=\"25\">for <span class=\"text-transparent bg-clip-text bg-[linear-gradient(135deg,var(--cyan),var(--magenta))]\" data-kid=\"26\">Better AI.</span>\n        </h1>\n        <p class=\"text-lg text-[var(--text-secondary)] max-w-xl mb-10 leading-relaxed\" data-kid=\"27\">\n          AI Evaluation, RLHF, and Quality Assurance designed for modern engineering teams. High-fidelity human judgment to scale your models.\n        </p>\n        <div class=\"flex flex-wrap gap-4\" data-kid=\"28\">\n          <button class=\"btn-magnetic px-8 py-4 bg-[var(--cyan)] text-black font-bold rounded-2xl hover:scale-105 transition-transform\" data-kid=\"29\">Schedule Call</button>\n          <button class=\"btn-magnetic px-8 py-4 glass border-[var(--cyan)]/20 font-bold rounded-2xl hover:bg-white/5\" data-kid=\"30\">Request Pilot</button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"col-span-12 lg:col-span-4 grid grid-cols-1 gap-6\" data-kid=\"31\">\n      <div class=\"glass rounded-3xl p-8 relative overflow-hidden reveal-up\" style=\"transition-delay: 100ms;\" data-kid=\"32\">\n        <img src=\"https://images.unsplash.com/photo-1667202374078-1683eda6b0b6?auto=format&w=800&q=80&fit=crop\" class=\"absolute top-0 right-0 w-full h-full object-cover opacity-20 -z-10\" loading=\"lazy\" decoding=\"async\" data-kid=\"33\">\n        <div class=\"text-[var(--cyan)] text-3xl mb-4\" data-kid=\"34\"><i class=\"ti ti-activity\" data-kid=\"35\"></i></div>\n        <h3 class=\"font-heading font-bold text-xl mb-2\" data-kid=\"36\">Real-time Quality</h3>\n        <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"37\">Multi-tier QA framework ensuring annotation accuracy and audit readiness.</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 flex flex-col justify-between reveal-up\" style=\"transition-delay: 200ms;\" data-kid=\"38\">\n        <div class=\"flex -space-x-3 mb-6\" data-kid=\"39\">\n          <div class=\"w-10 h-10 rounded-full border-2 border-[var(--bg)] bg-gray-800 flex items-center justify-center text-xs\" data-kid=\"40\">AI</div>\n          <div class=\"w-10 h-10 rounded-full border-2 border-[var(--bg)] bg-gray-700 flex items-center justify-center text-xs\" data-kid=\"41\">QA</div>\n          <div class=\"w-10 h-10 rounded-full border-2 border-[var(--bg)] bg-gray-600 flex items-center justify-center text-xs\" data-kid=\"42\">RL</div>\n        </div>\n        <div data-kid=\"43\">\n          <h3 class=\"font-heading font-bold text-xl mb-2\" data-kid=\"44\">Expert Human Loop</h3>\n          <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"45\">Domain-specific annotators for healthcare, finance, and frontier models.</p>\n        </div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-12 px-6\" data-kid=\"46\">\n  <div class=\"max-w-7xl mx-auto flex flex-wrap lg:flex-nowrap items-end gap-4\" data-kid=\"47\">\n    <div class=\"flex-1 glass p-8 rounded-3xl h-48 flex flex-col justify-end reveal-card\" data-kid=\"48\">\n      <div class=\"text-4xl font-heading font-bold text-[var(--cyan)] mb-1\" data-kid=\"49\">99.8%</div>\n      <div class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]\" data-kid=\"50\">Quality Accuracy</div>\n    </div>\n    <div class=\"flex-[0.8] glass p-8 rounded-3xl h-36 flex flex-col justify-end reveal-card\" data-kid=\"51\">\n      <div class=\"text-3xl font-heading font-bold text-[var(--magenta)] mb-1\" data-kid=\"52\">24h</div>\n      <div class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]\" data-kid=\"53\">Avg. Turnaround</div>\n    </div>\n    <div class=\"flex-[1.2] glass p-8 rounded-3xl h-56 flex flex-col justify-end reveal-card\" data-kid=\"54\">\n      <div class=\"text-5xl font-heading font-bold text-[var(--cyan)] mb-1\" data-kid=\"55\">50M+</div>\n      <div class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]\" data-kid=\"56\">Data Points Labeled</div>\n    </div>\n    <div class=\"flex-[0.9] glass p-8 rounded-3xl h-40 flex flex-col justify-end reveal-card\" data-kid=\"57\">\n      <div class=\"text-3xl font-heading font-bold text-[var(--magenta)] mb-1\" data-kid=\"58\">500+</div>\n      <div class=\"text-xs font-bold uppercase tracking-wider text-[var(--text-secondary)]\" data-kid=\"59\">Expert Annotators</div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-10 border-y border-white/5 overflow-hidden\" data-kid=\"60\">\n  <div class=\"animate-marquee\" data-kid=\"61\">\n    <div class=\"flex items-center gap-12 px-6\" data-kid=\"62\">\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"63\">AI EVALUATION</span>\n      <span class=\"text-[var(--cyan)] text-2xl\" data-kid=\"64\"><i class=\"ti ti-point-filled\" data-kid=\"65\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"66\">RLHF OPS</span>\n      <span class=\"text-[var(--magenta)] text-2xl\" data-kid=\"67\"><i class=\"ti ti-point-filled\" data-kid=\"68\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"69\">DATA ANNOTATION</span>\n      <span class=\"text-[var(--cyan)] text-2xl\" data-kid=\"70\"><i class=\"ti ti-point-filled\" data-kid=\"71\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"72\">RED TEAMING</span>\n      <span class=\"text-[var(--magenta)] text-2xl\" data-kid=\"73\"><i class=\"ti ti-point-filled\" data-kid=\"74\"></i></span>\n    </div>\n    <div class=\"flex items-center gap-12 px-6\" data-kid=\"75\">\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"76\">AI EVALUATION</span>\n      <span class=\"text-[var(--cyan)] text-2xl\" data-kid=\"77\"><i class=\"ti ti-point-filled\" data-kid=\"78\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"79\">RLHF OPS</span>\n      <span class=\"text-[var(--magenta)] text-2xl\" data-kid=\"80\"><i class=\"ti ti-point-filled\" data-kid=\"81\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"82\">DATA ANNOTATION</span>\n      <span class=\"text-[var(--cyan)] text-2xl\" data-kid=\"83\"><i class=\"ti ti-point-filled\" data-kid=\"84\"></i></span>\n      <span class=\"font-heading text-4xl font-bold text-transparent\" style=\"-webkit-text-stroke: 1px rgba(255,255,255,0.2);\" data-kid=\"85\">RED TEAMING</span>\n      <span class=\"text-[var(--magenta)] text-2xl\" data-kid=\"86\"><i class=\"ti ti-point-filled\" data-kid=\"87\"></i></span>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-24 px-6\" data-kid=\"88\">\n  <div class=\"max-w-7xl mx-auto\" data-kid=\"89\">\n    <div class=\"mb-16\" data-kid=\"90\">\n      <h2 class=\"font-heading text-4xl font-bold mb-4 reveal-up\" data-kid=\"91\">Full-Stack AI Operations</h2>\n      <p class=\"text-[var(--text-secondary)] max-w-2xl reveal-up\" data-kid=\"92\">Enterprise-grade data collection and evaluation infrastructure for frontier models.</p>\n    </div>\n\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-6\" data-kid=\"93\">\n      \n      <div class=\"md:col-span-2 md:row-span-2 glass rounded-3xl p-10 relative overflow-hidden neon-inset-cyan reveal-card\" data-kid=\"94\">\n        <img src=\"https://images.unsplash.com/photo-1727434032773-af3cd98375ba?auto=format&w=800&q=80&fit=crop\" class=\"absolute top-0 left-0 w-full h-full object-cover opacity-20 -z-10\" loading=\"lazy\" decoding=\"async\" data-kid=\"95\">\n        <div class=\"w-12 h-12 rounded-xl bg-[var(--cyan)]/10 flex items-center justify-center text-[var(--cyan)] mb-8\" data-kid=\"96\">\n          <i class=\"ti ti-layers-intersect text-2xl\" data-kid=\"97\"></i>\n        </div>\n        <h3 class=\"font-heading text-3xl font-bold mb-6\" data-kid=\"98\">AI Evaluation</h3>\n        <p class=\"text-[var(--text-secondary)] mb-8 leading-relaxed\" data-kid=\"99\">Systematic assessment of model outputs across quality, safety, and alignment dimensions. We provide custom rubrics and quality dashboards for LLM benchmarking.</p>\n        <ul class=\"space-y-3\" data-kid=\"100\">\n          <li class=\"flex items-center gap-3 text-sm text-[var(--text-secondary)]\" data-kid=\"101\"><span class=\"text-[var(--cyan)]\" data-kid=\"102\">●</span> Evaluation rubrics design</li>\n          <li class=\"flex items-center gap-3 text-sm text-[var(--text-secondary)]\" data-kid=\"103\"><span class=\"text-[var(--cyan)]\" data-kid=\"104\">●</span> Scaled human scoring</li>\n          <li class=\"flex items-center gap-3 text-sm text-[var(--text-secondary)]\" data-kid=\"105\"><span class=\"text-[var(--cyan)]\" data-kid=\"106\">●</span> Failure mode analysis</li>\n        </ul>\n      </div>\n\n      \n      <div class=\"glass rounded-3xl p-8 neon-inset-cyan reveal-card\" data-kid=\"107\">\n        <div class=\"text-[var(--magenta)] text-2xl mb-4\" data-kid=\"108\"><i class=\"ti ti-refresh\" data-kid=\"109\"></i></div>\n        <h4 class=\"font-heading font-bold text-xl mb-3\" data-kid=\"110\">RLHF Data</h4>\n        <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"111\">Preference pairs and ranking datasets for reward model training.</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 neon-inset-cyan reveal-card\" data-kid=\"112\">\n        <div class=\"text-[var(--cyan)] text-2xl mb-4\" data-kid=\"113\"><i class=\"ti ti-shield-check\" data-kid=\"114\"></i></div>\n        <h4 class=\"font-heading font-bold text-xl mb-3\" data-kid=\"115\">Red Teaming</h4>\n        <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"116\">Adversarial testing to identify jailbreaks and unsafe model outputs.</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 neon-inset-cyan reveal-card\" data-kid=\"117\">\n        <div class=\"text-[var(--magenta)] text-2xl mb-4\" data-kid=\"118\"><i class=\"ti ti-cpu\" data-kid=\"119\"></i></div>\n        <h4 class=\"font-heading font-bold text-xl mb-3\" data-kid=\"120\">Annotation</h4>\n        <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"121\">High-accuracy labeling for image, video, text across modalities.</p>\n      </div>\n      <div class=\"glass rounded-3xl p-8 neon-inset-cyan reveal-card\" data-kid=\"122\">\n        <div class=\"text-[var(--cyan)] text-2xl mb-4\" data-kid=\"123\"><i class=\"ti ti-chart-bar\" data-kid=\"124\"></i></div>\n        <h4 class=\"font-heading font-bold text-xl mb-3\" data-kid=\"125\">Benchmarking</h4>\n        <p class=\"text-sm text-[var(--text-secondary)]\" data-kid=\"126\">Comparative evaluation of models across technical domains.</p>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-24 px-6 relative\" data-kid=\"127\">\n  <div class=\"max-w-4xl mx-auto relative\" data-kid=\"128\">\n    <div class=\"s-curve-line\" data-kid=\"129\"></div>\n    \n    <div class=\"space-y-24\" data-kid=\"130\">\n      \n      <div class=\"flex items-center justify-between gap-12 relative z-10 reveal-up\" data-kid=\"131\">\n        <div class=\"flex-1 text-right pr-20\" data-kid=\"132\">\n          <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"133\">Discovery</h3>\n          <p class=\"text-[var(--text-secondary)] text-sm\" data-kid=\"134\">Understand your data, model, and quality requirements in a 30-minute call.</p>\n        </div>\n        <div class=\"w-12 h-12 rounded-full bg-black border-2 border-[var(--cyan)] flex items-center justify-center shrink-0 neon-cyan-glow\" data-kid=\"135\">\n          <span class=\"text-xs font-bold\" data-kid=\"136\">01</span>\n        </div>\n        <div class=\"flex-1 pl-20 hidden md:block\" data-kid=\"137\"></div>\n      </div>\n\n      \n      <div class=\"flex items-center justify-between gap-12 relative z-10 flex-row-reverse reveal-up\" data-kid=\"138\">\n        <div class=\"flex-1 text-left pl-20\" data-kid=\"139\">\n          <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"140\">Pilot Batch</h3>\n          <p class=\"text-[var(--text-secondary)] text-sm\" data-kid=\"141\">Execute a free sample batch on your actual data with our standard QA process.</p>\n        </div>\n        <div class=\"w-12 h-12 rounded-full bg-black border-2 border-[var(--magenta)] flex items-center justify-center shrink-0 neon-magenta-glow\" data-kid=\"142\">\n          <span class=\"text-xs font-bold\" data-kid=\"143\">02</span>\n        </div>\n        <div class=\"flex-1 pr-20 hidden md:block\" data-kid=\"144\"></div>\n      </div>\n\n      \n      <div class=\"flex items-center justify-between gap-12 relative z-10 reveal-up\" data-kid=\"145\">\n        <div class=\"flex-1 text-right pr-20\" data-kid=\"146\">\n          <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"147\">Alignment</h3>\n          <p class=\"text-[var(--text-secondary)] text-sm\" data-kid=\"148\">Refine annotation guidelines based on pilot feedback and edge cases.</p>\n        </div>\n        <div class=\"w-12 h-12 rounded-full bg-black border-2 border-[var(--cyan)] flex items-center justify-center shrink-0 neon-cyan-glow\" data-kid=\"149\">\n          <span class=\"text-xs font-bold\" data-kid=\"150\">03</span>\n        </div>\n        <div class=\"flex-1 pl-20 hidden md:block\" data-kid=\"151\"></div>\n      </div>\n\n      \n      <div class=\"flex items-center justify-between gap-12 relative z-10 flex-row-reverse reveal-up\" data-kid=\"152\">\n        <div class=\"flex-1 text-left pl-20\" data-kid=\"153\">\n          <h3 class=\"font-heading text-2xl font-bold mb-3\" data-kid=\"154\">Production</h3>\n          <p class=\"text-[var(--text-secondary)] text-sm\" data-kid=\"155\">Scale to full volume with established quality baselines and reporting.</p>\n        </div>\n        <div class=\"w-12 h-12 rounded-full bg-black border-2 border-[var(--magenta)] flex items-center justify-center shrink-0 neon-magenta-glow\" data-kid=\"156\">\n          <span class=\"text-xs font-bold\" data-kid=\"157\">04</span>\n        </div>\n        <div class=\"flex-1 pr-20 hidden md:block\" data-kid=\"158\"></div>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<section class=\"py-32 px-6\" data-kid=\"159\">\n  <div class=\"max-w-5xl mx-auto glass rounded-[40px] p-16 text-center relative overflow-hidden reveal-up\" data-kid=\"160\">\n    <div class=\"absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(0,240,255,0.05)_0%,transparent_70%)]\" data-kid=\"161\"></div>\n    <div class=\"relative z-10\" data-kid=\"162\">\n      <h2 class=\"font-heading text-5xl font-bold mb-8 leading-tight\" data-kid=\"163\">Ready to build better AI?</h2>\n      <p class=\"text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-12\" data-kid=\"164\">Join frontier model teams using YUG AI for high-fidelity human intelligence. Start with a free pilot batch today.</p>\n      <div class=\"flex flex-wrap justify-center gap-6\" data-kid=\"165\">\n        <button class=\"btn-magnetic px-12 py-5 bg-[var(--cyan)] text-black font-bold rounded-2xl text-lg hover:scale-105 transition-transform\" data-kid=\"166\">Schedule Discovery Call</button>\n        <button class=\"btn-magnetic px-12 py-5 glass border-[var(--magenta)]/30 text-[var(--magenta)] font-bold rounded-2xl text-lg hover:bg-white/5\" data-kid=\"167\">Request Pilot</button>\n      </div>\n    </div>\n  </div>\n</section>\n\n\n<footer class=\"py-20 px-6 border-t border-white/5\" data-kid=\"168\">\n  <div class=\"max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"169\">\n    <div class=\"col-span-1 md:col-span-2\" data-kid=\"170\">\n      <div class=\"flex items-center gap-2 mb-8\" data-kid=\"171\">\n        <div class=\"w-8 h-8 rounded-lg bg-[linear-gradient(135deg,var(--cyan),var(--magenta))] flex items-center justify-center\" data-kid=\"172\">\n          <span class=\"text-black font-bold text-xs\" data-kid=\"173\">YUG</span>\n        </div>\n        <span class=\"font-heading font-bold text-xl tracking-tight\" data-kid=\"174\">YUG AI</span>\n      </div>\n      <p class=\"text-[var(--text-secondary)] max-w-sm mb-8\" data-kid=\"175\">Enterprise AI operations agency specializing in AI Evaluation, RLHF, and high-fidelity human judgment.</p>\n      <div class=\"flex gap-4\" data-kid=\"176\">\n        <a href=\"#\" class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-xl hover:text-[var(--cyan)] transition-colors\" data-kid=\"177\"><i class=\"ti ti-brand-x\" data-kid=\"178\"></i></a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-xl hover:text-[var(--cyan)] transition-colors\" data-kid=\"179\"><i class=\"ti ti-brand-linkedin\" data-kid=\"180\"></i></a>\n        <a href=\"#\" class=\"w-10 h-10 rounded-full glass flex items-center justify-center text-xl hover:text-[var(--cyan)] transition-colors\" data-kid=\"181\"><i class=\"ti ti-brand-github\" data-kid=\"182\"></i></a>\n      </div>\n    </div>\n    <div data-kid=\"183\">\n      <h4 class=\"font-heading font-bold mb-6\" data-kid=\"184\">Company</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"185\">\n        <li data-kid=\"186\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"187\">About Us</a></li>\n        <li data-kid=\"188\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"189\">Our Approach</a></li>\n        <li data-kid=\"190\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"191\">Pilot Program</a></li>\n        <li data-kid=\"192\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"193\">Contact</a></li>\n      </ul>\n    </div>\n    <div data-kid=\"194\">\n      <h4 class=\"font-heading font-bold mb-6\" data-kid=\"195\">Solutions</h4>\n      <ul class=\"space-y-4 text-[var(--text-secondary)] text-sm\" data-kid=\"196\">\n        <li data-kid=\"197\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"198\">AI Evaluation</a></li>\n        <li data-kid=\"199\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"200\">RLHF Ops</a></li>\n        <li data-kid=\"201\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"202\">Data Annotation</a></li>\n        <li data-kid=\"203\"><a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"204\">Red Teaming</a></li>\n      </ul>\n    </div>\n  </div>\n  <div class=\"max-w-7xl mx-auto mt-20 pt-8 border-t border-white/5 flex flex-wrap justify-between gap-4 text-xs text-[var(--text-secondary)]\" data-kid=\"205\">\n    <p data-kid=\"206\">© 2024 YUG AI. All rights reserved.</p>\n    <div class=\"flex gap-8\" data-kid=\"207\">\n      <a href=\"#\" class=\"hover:text-white\" data-kid=\"208\">Privacy Policy</a>\n      <a href=\"#\" class=\"hover:text-white\" data-kid=\"209\">Terms of Service</a>\n    </div>\n  </div>\n</footer>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"210\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"211\"></script>\n<script type=\"module\" data-kid=\"212\">\n  import { animate, hover, inView } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Entrance Animations\n  gsap.from('.reveal-up', {\n    autoAlpha: 0,\n    y: 40,\n    duration: 1,\n    stagger: 0.2,\n    ease: 'power3.out'\n  });\n\n  gsap.from('.reveal-card', {\n    autoAlpha: 0,\n    scale: 0.95,\n    duration: 0.8,\n    stagger: 0.1,\n    ease: 'power2.out',\n    scrollTrigger: {\n      trigger: '.reveal-card',\n      start: 'top 85%'\n    }\n  });\n\n  // Magnetic Hover for Buttons\n  hover('.btn-magnetic', (el) => {\n    const move = (e) => {\n      const r = el.getBoundingClientRect();\n      animate(el, { \n        x: (e.clientX - r.left - r.width/2) * 0.3, \n        y: (e.clientY - r.top - r.height/2) * 0.3 \n      }, { type: 'spring', stiffness: 200, damping: 20 });\n    };\n    el.addEventListener('pointermove', move);\n    return () => {\n      el.removeEventListener('pointermove', move);\n      animate(el, { x: 0, y: 0 }, { type: 'spring' });\n    };\n  });\n\n  // Stats Count Up\n  inView('.reveal-card', () => {\n    // Logic for count up could go here if needed\n  });\n\n</script>",
