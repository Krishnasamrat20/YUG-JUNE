        "prompt": "",
        "config": {}
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Manrope:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --void-black: #050510;\n    --dark-ultramarine: #120A8F;\n    --violet: #8A2BE2;\n    --cyan: #00FFFF;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--void-black);\n    color: #ffffff;\n    font-family: 'Manrope', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, h4, .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .aurora {\n    background: radial-gradient(circle at 20% 30%, var(--dark-ultramarine) 0%, transparent 40%),\n                radial-gradient(circle at 80% 70%, var(--violet) 0%, transparent 40%),\n                radial-gradient(circle at 50% 50%, #0a0a20 0%, transparent 60%);\n    background-size: 200% 200%;\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--violet), var(--dark-ultramarine));\n    border: 1px solid var(--cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.2);\n  }\n\n  .service-card {\n    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;\n  }\n\n  .service-card:hover {\n    border-color: var(--cyan);\n    box-shadow: 0 0 30px rgba(0, 255, 255, 0.1);\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center backdrop-blur-md border-b border-white/5\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"5\"></div>\n        <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"6\">YUG AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/70\" data-kid=\"7\">\n        <a href=\"#\" class=\"text-white\" data-kid=\"8\">Services</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"9\">Industries</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"10\">Portfolio</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"11\">About</a>\n        <a href=\"#\" class=\"px-5 py-2.5 glass text-white hover:border-cyan-400/50 transition-all\" data-kid=\"12\">Contact Us</a>\n      </div>\n    </nav>\n\n    \n    <section class=\"relative pt-40 pb-20 overflow-hidden aurora\" data-kid=\"13\">\n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"14\">\n        <div class=\"max-w-3xl space-y-6\" data-kid=\"15\">\n          <div class=\"inline-flex items-center gap-3 px-4 py-2 glass border-cyan-400/20 text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"16\">\n            <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"17\"></span>\n            Our Capabilities\n          </div>\n          <h1 class=\"text-6xl lg:text-8xl font-outfit font-bold leading-[1.1]\" data-kid=\"18\">\n            Full-stack AI operations <br data-kid=\"19\"> <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-violet-500 to-fuchsia-500\" data-kid=\"20\">under one roof.</span>\n          </h1>\n          <p class=\"text-xl text-white/60 max-w-xl leading-relaxed\" data-kid=\"21\">\n            From evaluation rubrics to delivery-ready datasets — we handle the full spectrum of AI data operations.\n          </p>\n          <div class=\"flex flex-wrap gap-4 pt-4\" data-kid=\"22\">\n            <button class=\"btn-primary px-8 py-4 rounded-full font-bold text-lg\" data-kid=\"23\">Schedule Discovery Call</button>\n            <button class=\"glass px-8 py-4 rounded-full font-bold text-lg hover:bg-white/10 transition-colors\" data-kid=\"24\">Request Pilot Proposal</button>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-24 bg-void-black\" data-kid=\"25\">\n      <div class=\"container mx-auto px-6\" data-kid=\"26\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\" id=\"services-grid\" data-kid=\"27\">\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between\" data-kid=\"28\">\n            <div class=\"space-y-6\" data-kid=\"29\">\n              <div class=\"w-14 h-14 rounded-2xl bg-cyan-600/20 flex items-center justify-center text-cyan-400\" data-kid=\"30\">\n                <i class=\"ti ti-activity text-3xl\" data-kid=\"31\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"32\">\n                <div class=\"flex items-center gap-3\" data-kid=\"33\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"34\">AI Evaluation</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-cyan-500/10 text-cyan-300 text-[10px] font-bold uppercase tracking-wider border border-cyan-500/20\" data-kid=\"35\">Evaluation</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"36\">Systematic assessment of AI model outputs for quality, safety, and alignment.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-cyan-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"37\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"38\"></i>\n            </a>\n          </div>\n\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between border-violet-500/20\" data-kid=\"39\">\n            <div class=\"space-y-6\" data-kid=\"40\">\n              <div class=\"w-14 h-14 rounded-2xl bg-violet-600/20 flex items-center justify-center text-violet-400\" data-kid=\"41\">\n                <i class=\"ti ti-layers-intersect text-3xl\" data-kid=\"42\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"43\">\n                <div class=\"flex items-center gap-3\" data-kid=\"44\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"45\">RLHF Ops</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-violet-500/10 text-violet-300 text-[10px] font-bold uppercase tracking-wider border border-violet-500/20\" data-kid=\"46\">RLHF</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"47\">Human preference data for reinforcement learning from human feedback.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-violet-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"48\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"49\"></i>\n            </a>\n          </div>\n\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between\" data-kid=\"50\">\n            <div class=\"space-y-6\" data-kid=\"51\">\n              <div class=\"w-14 h-14 rounded-2xl bg-cyan-600/20 flex items-center justify-center text-cyan-400\" data-kid=\"52\">\n                <i class=\"ti ti-photo text-3xl\" data-kid=\"53\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"54\">\n                <div class=\"flex items-center gap-3\" data-kid=\"55\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"56\">Data Annotation</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-cyan-500/10 text-cyan-300 text-[10px] font-bold uppercase tracking-wider border border-cyan-500/20\" data-kid=\"57\">Annotation</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"58\">High-accuracy labeling across image, video, text, and audio modalities.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-cyan-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"59\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"60\"></i>\n            </a>\n          </div>\n\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between border-violet-500/20\" data-kid=\"61\">\n            <div class=\"space-y-6\" data-kid=\"62\">\n              <div class=\"w-14 h-14 rounded-2xl bg-violet-600/20 flex items-center justify-center text-violet-400\" data-kid=\"63\">\n                <i class=\"ti ti-shield-lock text-3xl\" data-kid=\"64\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"65\">\n                <div class=\"flex items-center gap-3\" data-kid=\"66\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"67\">Red Teaming</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-violet-500/10 text-violet-300 text-[10px] font-bold uppercase tracking-wider border border-violet-500/20\" data-kid=\"68\">Safety</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"69\">Adversarial testing to surface failure modes and unsafe model outputs.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-violet-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"70\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"71\"></i>\n            </a>\n          </div>\n\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between\" data-kid=\"72\">\n            <div class=\"space-y-6\" data-kid=\"73\">\n              <div class=\"w-14 h-14 rounded-2xl bg-cyan-600/20 flex items-center justify-center text-cyan-400\" data-kid=\"74\">\n                <i class=\"ti ti-shield-check text-3xl\" data-kid=\"75\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"76\">\n                <div class=\"flex items-center gap-3\" data-kid=\"77\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"78\">Quality Assurance</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-cyan-500/10 text-cyan-300 text-[10px] font-bold uppercase tracking-wider border border-cyan-500/20\" data-kid=\"79\">QA</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"80\">3-tier QA model with gold sets, IAA tracking, and detailed audit logs.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-cyan-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"81\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"82\"></i>\n            </a>\n          </div>\n\n          \n          <div class=\"glass p-8 space-y-8 service-card flex flex-col justify-between border-violet-500/20\" data-kid=\"83\">\n            <div class=\"space-y-6\" data-kid=\"84\">\n              <div class=\"w-14 h-14 rounded-2xl bg-violet-600/20 flex items-center justify-center text-violet-400\" data-kid=\"85\">\n                <i class=\"ti ti-settings text-3xl\" data-kid=\"86\"></i>\n              </div>\n              <div class=\"space-y-3\" data-kid=\"87\">\n                <div class=\"flex items-center gap-3\" data-kid=\"88\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"89\">Workflow Design</h3>\n                  <span class=\"px-3 py-1 rounded-full bg-violet-500/10 text-violet-300 text-[10px] font-bold uppercase tracking-wider border border-violet-500/20\" data-kid=\"90\">Strategy</span>\n                </div>\n                <p class=\"text-white/50 leading-relaxed\" data-kid=\"91\">Taxonomy design, guideline authoring, and annotation workflow architecture.</p>\n              </div>\n            </div>\n            <a href=\"#\" class=\"text-violet-400 font-bold text-sm flex items-center gap-2 group\" data-kid=\"92\">\n              Learn More <i class=\"ti ti-arrow-right group-hover:translate-x-1 transition-transform\" data-kid=\"93\"></i>\n            </a>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-[#080815] relative overflow-hidden text-center\" data-kid=\"94\">\n      <div class=\"absolute inset-0 bg-gradient-to-t from-violet-900/10 to-transparent\" data-kid=\"95\"></div>\n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"96\">\n        <div class=\"max-w-2xl mx-auto space-y-8\" data-kid=\"97\">\n          <h2 class=\"text-5xl lg:text-7xl font-outfit font-bold\" data-kid=\"98\">Start with a <br data-kid=\"99\"> <span class=\"text-cyan-400\" data-kid=\"100\">free pilot.</span></h2>\n          <p class=\"text-xl text-white/50 leading-relaxed\" data-kid=\"101\">\n            No commitment. Validate our quality standards on your actual production data before scaling operations.\n          </p>\n          <button class=\"btn-primary px-12 py-5 rounded-full font-bold text-xl\" data-kid=\"102\">Request Pilot Proposal</button>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"py-20 border-t border-white/5 bg-[#030308]\" data-kid=\"103\">\n      <div class=\"container mx-auto px-6\" data-kid=\"104\">\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"105\">\n          <div class=\"col-span-2 space-y-6\" data-kid=\"106\">\n            <div class=\"flex items-center gap-2\" data-kid=\"107\">\n              <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"108\"></div>\n              <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"109\">YUG AI</span>\n            </div>\n            <p class=\"text-white/40 max-w-sm leading-relaxed\" data-kid=\"110\">Precision human intelligence for modern AI teams. Built for safety, accuracy, and enterprise-scale operations.</p>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"111\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"112\">Services</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"113\">\n              <li data-kid=\"114\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"115\">AI Evaluation</a></li>\n              <li data-kid=\"116\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"117\">RLHF Ops</a></li>\n              <li data-kid=\"118\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"119\">Data Annotation</a></li>\n              <li data-kid=\"120\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"121\">Red Teaming</a></li>\n            </ul>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"122\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"123\">Company</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"124\">\n              <li data-kid=\"125\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"126\">About</a></li>\n              <li data-kid=\"127\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"128\">Portfolio</a></li>\n              <li data-kid=\"129\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"130\">Contact</a></li>\n              <li data-kid=\"131\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"132\">Privacy Policy</a></li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-[0.2em] text-white/20\" data-kid=\"133\">\n          <span data-kid=\"134\">© 2026 YUG AI OPERATIONS</span>\n          <div class=\"flex gap-8\" data-kid=\"135\">\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"136\">Twitter</a>\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"137\">LinkedIn</a>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"138\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"139\"></script>\n<script type=\"module\" data-kid=\"140\">\n  import { animate, inView, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate } from 'https://esm.sh/animejs@4'\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Smooth Scrolling\n  const lenis = new Lenis()\n  lenis.on('scroll', ScrollTrigger.update)\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000)\n  })\n  gsap.ticker.lagSmoothing(0)\n\n  // Aurora Gradient Animation\n  animeAnimate('.aurora', {\n    backgroundPosition: ['0% 0%', '100% 50%', '0% 100%', '0% 0%'],\n    duration: 20000,\n    loop: true,\n    ease: 'linear'\n  });\n\n  // Entrance Animations\n  gsap.from('.max-w-3xl > *', {\n    autoAlpha: 0,\n    y: 30,\n    duration: 1,\n    stagger: 0.1,\n    ease: 'power3.out'\n  });\n\n  // Services Stagger Reveal\n  gsap.from('.service-card', {\n    scrollTrigger: {\n      trigger: '#services-grid',\n      start: 'top 80%'\n    },\n    autoAlpha: 0,\n    scale: 0.9,\n    y: 40,\n    stagger: 0.1,\n    duration: 0.8,\n    ease: 'back.out(1.4)'\n  });\n\n  // Magnetic Button Effect\n  document.querySelectorAll('.btn-primary, .glass').forEach(btn => {\n    btn.addEventListener('mousemove', (e) => {\n      const rect = btn.getBoundingClientRect();\n      const x = e.clientX - rect.left - rect.width / 2;\n      const y = e.clientY - rect.top - rect.height / 2;\n      gsap.to(btn, {\n        x: x * 0.3,\n        y: y * 0.3,\n        duration: 0.4,\n        ease: 'power2.out'\n      });\n    });\n    btn.addEventListener('mouseleave', () => {\n      gsap.to(btn, {\n        x: 0,\n        y: 0,\n        duration: 0.6,\n        ease: 'elastic.out(1, 0.3)'\n      });\n    });\n  });\n\n</script>",
