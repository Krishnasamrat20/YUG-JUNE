      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Manrope:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --void-black: #050510;\n    --dark-ultramarine: #120A8F;\n    --violet: #8A2BE2;\n    --cyan: #00FFFF;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--void-black);\n    color: #ffffff;\n    font-family: 'Manrope', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, h4, .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .aurora {\n    background: radial-gradient(circle at 20% 30%, var(--dark-ultramarine) 0%, transparent 40%),\n                radial-gradient(circle at 80% 70%, var(--violet) 0%, transparent 40%),\n                radial-gradient(circle at 50% 50%, #0a0a20 0%, transparent 60%);\n    background-size: 200% 200%;\n  }\n\n  .floating-island {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-20px); }\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--violet), var(--dark-ultramarine));\n    border: 1px solid var(--cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);\n    transition: none; /* GSAP handles this */\n  }\n\n  .gold-line {\n    display: block;\n    width: 40px;\n    height: 2px;\n    background: var(--cyan); /* Using Cyan as the 'gold' replacement in Deep Nebula theme */\n  }\n\n  .team-image-container {\n    border: 2px solid rgba(0, 255, 255, 0.25);\n    box-shadow: 0 0 28px rgba(0, 255, 255, 0.1);\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center backdrop-blur-md border-b border-white/5\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"5\"></div>\n        <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"6\">YUG AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/70\" data-kid=\"7\">\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"8\">Services</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"9\">Industries</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"10\">Portfolio</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"11\">About</a>\n        <a href=\"#\" class=\"px-5 py-2.5 glass text-white hover:border-cyan-400/50 transition-all\" data-kid=\"12\">Contact Us</a>\n      </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-[70vh] flex items-center pt-32 pb-20 overflow-hidden aurora\" data-kid=\"13\">\n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"14\">\n        <div class=\"max-w-4xl space-y-8 animate-reveal\" data-kid=\"15\">\n          <div class=\"inline-flex items-center gap-3 px-4 py-2 glass border-cyan-400/20 text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"16\">\n            <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"17\"></span>\n            About YUG AI\n          </div>\n          <h1 class=\"text-6xl lg:text-8xl font-outfit font-bold leading-[1.1]\" data-kid=\"18\">\n            A founder-led company<br data-kid=\"19\">\n            <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-violet-500 to-fuchsia-500\" data-kid=\"20\">built for AI teams.</span>\n          </h1>\n          <p class=\"text-xl text-white/60 max-w-2xl leading-relaxed\" data-kid=\"21\">\n            We help AI teams improve model quality through structured human feedback systems — evaluation, RLHF, annotation, and QA operations built for the way modern AI teams actually work.\n          </p>\n        </div>\n      </div>\n      \n      <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1763259502801-3d655a106e02?auto=format&w=1440&q=80&fit=crop')] opacity-10 mix-blend-overlay\" data-kid=\"22\"></div>\n    </section>\n\n    \n    <section class=\"py-24 relative z-10\" data-kid=\"23\">\n      <div class=\"container mx-auto px-6\" data-kid=\"24\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-8 mb-24\" data-kid=\"25\">\n          <div class=\"glass p-10 space-y-6 animate-reveal\" data-kid=\"26\">\n            <span class=\"gold-line\" data-kid=\"27\"></span>\n            <p class=\"text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"28\">Mission</p>\n            <h2 class=\"text-3xl font-outfit font-bold leading-tight\" data-kid=\"29\">Make AI models better through structured human intelligence.</h2>\n            <p class=\"text-white/60 leading-relaxed\" data-kid=\"30\">\n              We believe AI quality is fundamentally a human problem. The best models are trained, evaluated, and improved with structured, expert human input — not volume alone.\n            </p>\n          </div>\n          <div class=\"glass p-10 space-y-6 animate-reveal\" style=\"transition-delay: 0.1s\" data-kid=\"31\">\n            <span class=\"gold-line\" data-kid=\"32\"></span>\n            <p class=\"text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"33\">Operational Philosophy</p>\n            <h2 class=\"text-3xl font-outfit font-bold leading-tight\" data-kid=\"34\">Process-first. Quality-obsessed. Founder-accountable.</h2>\n            <p class=\"text-white/60 leading-relaxed\" data-kid=\"35\">\n              Every engagement starts with a pilot. Every batch is validated against gold sets. Every delivery comes with a QA report. No black boxes, no hollow metrics.\n            </p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 relative overflow-hidden bg-[#080815]\" data-kid=\"36\">\n      <div class=\"absolute inset-0 aurora opacity-20\" data-kid=\"37\"></div>\n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"38\">\n        <div class=\"text-center mb-24 space-y-4 animate-reveal\" data-kid=\"39\">\n          <p class=\"text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"40\">Values</p>\n          <h2 class=\"text-5xl font-outfit font-bold\" data-kid=\"41\">How we operate.</h2>\n        </div>\n\n        <div class=\"relative h-[500px] flex items-center justify-center\" data-kid=\"42\">\n          <div class=\"absolute top-0 left-[10%] glass px-8 py-6 max-w-xs floating-island border-cyan-400/30 space-y-3 bg-void-black/80 animate-reveal\" data-kid=\"43\">\n            <div class=\"text-cyan-400 text-2xl font-bold\" data-kid=\"44\">◎</div>\n            <h3 class=\"font-outfit font-bold\" data-kid=\"45\">Accuracy Before Volume</h3>\n            <p class=\"text-sm text-white/50\" data-kid=\"46\">We would rather deliver fewer, higher-quality labels than large batches of mediocre data.</p>\n          </div>\n          <div class=\"absolute top-20 right-[15%] glass px-8 py-6 max-w-xs floating-island border-violet-400/30 space-y-3 bg-void-black/80 animate-reveal\" style=\"animation-delay: -2s\" data-kid=\"47\">\n            <div class=\"text-violet-400 text-2xl font-bold\" data-kid=\"48\">✦</div>\n            <h3 class=\"font-outfit font-bold\" data-kid=\"49\">Transparency by Default</h3>\n            <p class=\"text-sm text-white/50\" data-kid=\"50\">Clients receive QA reports, IAA metrics, and reviewer notes on every single delivery.</p>\n          </div>\n          <div class=\"absolute bottom-10 left-[20%] glass px-8 py-6 max-w-xs floating-island border-cyan-400/30 space-y-3 bg-void-black/80 animate-reveal\" style=\"animation-delay: -4s\" data-kid=\"51\">\n            <div class=\"text-cyan-400 text-2xl font-bold\" data-kid=\"52\">◈</div>\n            <h3 class=\"font-outfit font-bold\" data-kid=\"53\">Founder-Led Delivery</h3>\n            <p class=\"text-sm text-white/50\" data-kid=\"54\">Leadership is directly involved in quality standards and client engagements — always.</p>\n          </div>\n          <div class=\"absolute bottom-0 right-[25%] glass px-8 py-6 max-w-xs floating-island border-violet-400/30 space-y-3 bg-void-black/80 animate-reveal\" style=\"animation-delay: -1s\" data-kid=\"55\">\n            <div class=\"text-violet-400 text-2xl font-bold\" data-kid=\"56\">↺</div>\n            <h3 class=\"font-outfit font-bold\" data-kid=\"57\">Pilot-First Philosophy</h3>\n            <p class=\"text-sm text-white/50\" data-kid=\"58\">We earn trust through results before production commitments. Every engagement starts with a pilot.</p>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-void-black relative\" data-kid=\"59\">\n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"60\">\n        <div class=\"flex flex-col md:flex-row justify-between items-end mb-20 gap-8 animate-reveal\" data-kid=\"61\">\n          <div class=\"max-w-2xl space-y-4\" data-kid=\"62\">\n            <p class=\"text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"63\">Founding Team</p>\n            <h2 class=\"text-5xl lg:text-6xl font-outfit font-bold\" data-kid=\"64\">The people behind <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-violet-500\" data-kid=\"65\">YUG AI.</span></h2>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"66\">\n          <div class=\"glass p-8 text-center space-y-6 group hover:border-cyan-400/50 transition-all animate-reveal\" style=\"--i: 0\" data-kid=\"67\">\n            <div class=\"w-24 h-24 rounded-full mx-auto overflow-hidden team-image-container group-hover:border-cyan-400 transition-all\" data-kid=\"68\">\n              <img src=\"/api/local/images/p2.png\" alt=\"Krishna Samrat Bajpai\" class=\"w-full h-full object-cover\" data-kid=\"69\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"70\">\n              <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"71\">Krishna Samrat Bajpai</h3>\n              <p class=\"text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"72\">Co-Founder</p>\n              <span class=\"gold-line mx-auto opacity-30\" data-kid=\"73\"></span>\n              <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"74\">Overseeing product vision, client relationships, and delivery standards across all engagements.</p>\n            </div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-6 group hover:border-violet-400/50 transition-all animate-reveal\" style=\"--i: 1\" data-kid=\"75\">\n            <div class=\"w-24 h-24 rounded-full mx-auto overflow-hidden team-image-container group-hover:border-violet-400 transition-all\" data-kid=\"76\">\n              <img src=\"/api/local/images/p1.png\" alt=\"Priyesh Singh\" class=\"w-full h-full object-cover\" data-kid=\"77\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"78\">\n              <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"79\">Priyesh Singh</h3>\n              <p class=\"text-xs font-bold text-violet-400 uppercase tracking-widest\" data-kid=\"80\">Co-Founder</p>\n              <span class=\"gold-line mx-auto opacity-30\" data-kid=\"81\"></span>\n              <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"82\">Driving AI strategy, annotation operations, and data pipeline delivery at production scale.</p>\n            </div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-6 group hover:border-cyan-400/50 transition-all animate-reveal\" style=\"--i: 2\" data-kid=\"83\">\n            <div class=\"w-24 h-24 rounded-full mx-auto overflow-hidden team-image-container group-hover:border-cyan-400 transition-all\" data-kid=\"84\">\n              <img src=\"/api/local/images/p4.png\" alt=\"Abhishek Singh\" class=\"w-full h-full object-cover\" data-kid=\"85\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"86\">\n              <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"87\">Abhishek Singh</h3>\n              <p class=\"text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"88\">Co-Founder</p>\n              <span class=\"gold-line mx-auto opacity-30\" data-kid=\"89\"></span>\n              <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"90\">Leading engineering, QA systems, and technical delivery infrastructure for AI data operations.</p>\n            </div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-6 group hover:border-violet-400/50 transition-all animate-reveal\" style=\"--i: 3\" data-kid=\"91\">\n            <div class=\"w-24 h-24 rounded-full mx-auto overflow-hidden team-image-container group-hover:border-violet-400 transition-all\" data-kid=\"92\">\n              <img src=\"/api/local/images/p3.png\" alt=\"Shreshth Bajpai\" class=\"w-full h-full object-cover\" data-kid=\"93\">\n            </div>\n            <div class=\"space-y-2\" data-kid=\"94\">\n              <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"95\">Shreshth Bajpai</h3>\n              <p class=\"text-xs font-bold text-violet-400 uppercase tracking-widest\" data-kid=\"96\">Co-Founder</p>\n              <span class=\"gold-line mx-auto opacity-30\" data-kid=\"97\"></span>\n              <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"98\">Building partnerships, go-to-market strategy, and enterprise client development globally.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-[#050510] relative overflow-hidden\" data-kid=\"99\">\n      <div id=\"peephole-mask\" class=\"absolute inset-0 bg-cyan-600 z-0 scale-0 rounded-full opacity-10 blur-[100px]\" data-kid=\"100\"></div>\n      <div class=\"container mx-auto px-6 relative z-10 text-center space-y-12\" data-kid=\"101\">\n        <div class=\"space-y-4 animate-reveal\" data-kid=\"102\">\n          <h2 class=\"text-5xl lg:text-7xl font-outfit font-bold tracking-tight\" data-kid=\"103\">Work with a team that takes <span class=\"text-cyan-400\" data-kid=\"104\">quality seriously.</span></h2>\n          <p class=\"text-xl text-white/50 max-w-2xl mx-auto\" data-kid=\"105\">Start with a free pilot on your actual data. No commitment required.</p>\n        </div>\n        <div class=\"flex flex-col md:flex-row items-center justify-center gap-6 animate-reveal\" data-kid=\"106\">\n          <button class=\"btn-primary px-12 py-5 rounded-full font-bold text-xl group\" data-kid=\"107\">\n             Schedule Discovery Call\n             <i class=\"ti ti-arrow-right ml-2 group-hover:translate-x-1 transition-transform\" data-kid=\"108\"></i>\n          </button>\n          <button class=\"glass px-12 py-5 rounded-full font-bold text-xl hover:bg-white/10 transition-colors\" data-kid=\"109\">\n             Request Pilot Proposal\n          </button>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"py-20 border-t border-white/5 bg-[#030308]\" data-kid=\"110\">\n      <div class=\"container mx-auto px-6\" data-kid=\"111\">\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 text-center md:text-left\" data-kid=\"112\">\n          <div class=\"col-span-1 md:col-span-2 space-y-6\" data-kid=\"113\">\n            <div class=\"flex items-center justify-center md:justify-start gap-2\" data-kid=\"114\">\n              <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"115\"></div>\n              <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"116\">YUG AI</span>\n            </div>\n            <p class=\"text-white/40 max-w-sm mx-auto md:mx-0 leading-relaxed\" data-kid=\"117\">Precision human intelligence for modern AI teams. Built for safety, accuracy, and enterprise-scale operations.</p>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"118\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"119\">Services</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"120\">\n              <li data-kid=\"121\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"122\">AI Evaluation</a></li>\n              <li data-kid=\"123\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"124\">RLHF Ops</a></li>\n              <li data-kid=\"125\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"126\">Data Annotation</a></li>\n              <li data-kid=\"127\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"128\">Red Teaming</a></li>\n            </ul>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"129\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"130\">Company</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"131\">\n              <li data-kid=\"132\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"133\">About</a></li>\n              <li data-kid=\"134\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"135\">Portfolio</a></li>\n              <li data-kid=\"136\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"137\">Contact</a></li>\n              <li data-kid=\"138\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"139\">Privacy Policy</a></li>\n            </ul>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"140\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"141\"></script>\n<script type=\"module\" data-kid=\"142\">\n  import { animate, inView, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate, stagger as animeStagger } from 'https://esm.sh/animejs@4'\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Smooth Scrolling\n  const lenis = new Lenis()\n  lenis.on('scroll', ScrollTrigger.update)\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000)\n  })\n  gsap.ticker.lagSmoothing(0)\n\n  // Aurora Gradient Animation\n  animeAnimate('.aurora', {\n    backgroundPosition: ['0% 0%', '100% 50%', '0% 100%', '0% 0%'],\n    duration: 20000,\n    loop: true,\n    ease: 'linear'\n  });\n\n  // Floating Islands Loop\n  document.querySelectorAll('.floating-island').forEach((el, i) => {\n    animeAnimate(el, {\n      y: [-15, 15],\n      duration: 3000 + i * 800,\n      alternate: true,\n      loop: true,\n      ease: 'inOut(2)'\n    });\n  });\n\n  // Entrance Reveal Sections\n  gsap.set('.animate-reveal', { autoAlpha: 0, y: 40 });\n  ScrollTrigger.batch('.animate-reveal', {\n    onEnter: batch => gsap.to(batch, { autoAlpha: 1, y: 0, stagger: 0.15, duration: 1, ease: 'power3.out' }),\n    start: 'top 85%'\n  });\n\n  // CTA Peephole Mask Expansion\n  gsap.to('#peephole-mask', {\n    scrollTrigger: {\n      trigger: '#cta-section',\n      start: 'top bottom',\n      end: 'center center',\n      scrub: true\n    },\n    scale: 15,\n    opacity: 0.4\n  });\n\n  // Magnetic Button Effect\n  const handleMagnetic = (e, btn) => {\n    const rect = btn.getBoundingClientRect();\n    const x = e.clientX - rect.left - rect.width / 2;\n    const y = e.clientY - rect.top - rect.height / 2;\n    gsap.to(btn, {\n      x: x * 0.35,\n      y: y * 0.35,\n      duration: 0.4,\n      ease: 'power2.out'\n    });\n  };\n\n  const resetMagnetic = (btn) => {\n    gsap.to(btn, {\n      x: 0,\n      y: 0,\n      duration: 0.8,\n      ease: 'elastic.out(1, 0.3)'\n    });\n  };\n\n  document.querySelectorAll('.btn-primary, .glass, button').forEach(btn => {\n    if (btn.classList.contains('fixed')) return; // skip fixed nav\n    btn.addEventListener('mousemove', (e) => handleMagnetic(e, btn));\n    btn.addEventListener('mouseleave', () => resetMagnetic(btn));\n  });\n\n</script>",
