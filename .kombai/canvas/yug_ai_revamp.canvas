      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700&family=Manrope:wght@400;500;600&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n  @import url('https://unpkg.com/lenis@1/dist/lenis.css');\n\n  :root {\n    --void-black: #050510;\n    --dark-ultramarine: #120A8F;\n    --violet: #8A2BE2;\n    --cyan: #00FFFF;\n    --glass-bg: rgba(255, 255, 255, 0.03);\n    --glass-border: rgba(255, 255, 255, 0.1);\n  }\n\n  body {\n    background-color: var(--void-black);\n    color: #ffffff;\n    font-family: 'Manrope', sans-serif;\n    margin: 0;\n    overflow-x: clip;\n  }\n\n  h1, h2, h3, h4, .font-outfit {\n    font-family: 'Outfit', sans-serif;\n  }\n\n  .glass {\n    background: var(--glass-bg);\n    backdrop-filter: blur(16px);\n    border: 1px solid var(--glass-border);\n    border-radius: 24px;\n    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);\n  }\n\n  .aurora {\n    background: radial-gradient(circle at 20% 30%, var(--dark-ultramarine) 0%, transparent 40%),\n                radial-gradient(circle at 80% 70%, var(--violet) 0%, transparent 40%),\n                radial-gradient(circle at 50% 50%, #0a0a20 0%, transparent 60%);\n    background-size: 200% 200%;\n  }\n\n  .floating-island {\n    animation: float 6s ease-in-out infinite;\n  }\n\n  @keyframes float {\n    0%, 100% { transform: translateY(0); }\n    50% { transform: translateY(-20px); }\n  }\n\n  .btn-primary {\n    background: linear-gradient(135deg, var(--violet), var(--dark-ultramarine));\n    border: 1px solid var(--cyan);\n    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);\n    transition: all 0.3s ease;\n  }\n\n  .btn-primary:hover {\n    box-shadow: 0 0 25px rgba(0, 255, 255, 0.6);\n    transform: scale(1.05);\n  }\n\n  .diagonal-ticker {\n    transform: rotate(-2deg);\n    width: 120%;\n    margin-left: -10%;\n  }\n\n  .dot-line::before {\n    content: '';\n    position: absolute;\n    left: 15px;\n    top: 0;\n    bottom: 0;\n    width: 2px;\n    background: linear-gradient(to bottom, var(--violet), var(--cyan));\n  }\n\n  .qa-card-stack {\n    perspective: 1000px;\n  }\n</style>\n\n<div id=\"smooth-wrapper\" data-kid=\"1\">\n  <div id=\"smooth-content\" data-kid=\"2\">\n    \n    <nav class=\"fixed top-0 left-0 w-full z-50 px-8 py-6 flex justify-between items-center backdrop-blur-md border-b border-white/5\" data-kid=\"3\">\n      <div class=\"flex items-center gap-2\" data-kid=\"4\">\n        <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"5\"></div>\n        <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"6\">YUG AI</span>\n      </div>\n      <div class=\"hidden md:flex items-center gap-8 text-sm font-medium text-white/70\" data-kid=\"7\">\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"8\">Services</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"9\">Industries</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"10\">Portfolio</a>\n        <a href=\"#\" class=\"hover:text-cyan-400 transition-colors\" data-kid=\"11\">About</a>\n        <a href=\"#\" class=\"px-5 py-2.5 glass text-white hover:border-cyan-400/50 transition-all\" data-kid=\"12\">Contact Us</a>\n      </div>\n    </nav>\n\n    \n    <section class=\"relative min-h-screen flex items-center justify-center pt-20 overflow-hidden aurora\" data-kid=\"13\">\n      <div class=\"absolute inset-0 bg-[url('https://images.unsplash.com/photo-1708778002531-5bb1c27c4ea3?auto=format&w=1440&q=80&fit=crop')] opacity-20 mix-blend-overlay\" data-kid=\"14\"></div>\n      \n      <div class=\"container mx-auto px-6 relative z-10\" data-kid=\"15\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center\" data-kid=\"16\">\n          <div class=\"lg:col-span-7 space-y-8\" data-kid=\"17\">\n            <div class=\"inline-flex items-center gap-3 px-4 py-2 glass border-cyan-400/20 text-cyan-400 text-xs font-bold uppercase tracking-widest\" data-kid=\"18\">\n              <span class=\"w-2 h-2 rounded-full bg-cyan-400 animate-pulse\" data-kid=\"19\"></span>\n              Human Intelligence for Better AI\n            </div>\n            <h1 class=\"text-6xl lg:text-8xl font-outfit font-bold leading-[1.1]\" data-kid=\"20\">\n              Architecting the <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 via-violet-500 to-fuchsia-500\" data-kid=\"21\">Future of AI</span> Data.\n            </h1>\n            <p class=\"text-xl text-white/60 max-w-xl leading-relaxed\" data-kid=\"22\">\n              AI Evaluation, RLHF, and high-fidelity Annotation Operations. We provide the human-in-the-loop intelligence your frontier models demand.\n            </p>\n            <div class=\"flex flex-wrap gap-4 pt-4\" data-kid=\"23\">\n              <button class=\"btn-primary px-8 py-4 rounded-full font-bold text-lg\" data-kid=\"24\">Discovery Call</button>\n              <button class=\"glass px-8 py-4 rounded-full font-bold text-lg hover:bg-white/10 transition-colors\" data-kid=\"25\">Request Pilot</button>\n            </div>\n          </div>\n\n          <div class=\"lg:col-span-5 relative\" data-kid=\"26\">\n            <div class=\"grid grid-cols-2 gap-4\" data-kid=\"27\">\n              <div class=\"glass p-6 space-y-4 translate-y-8\" data-kid=\"28\">\n                <div class=\"w-12 h-12 rounded-xl bg-violet-600/20 flex items-center justify-center text-violet-400\" data-kid=\"29\">\n                  <i class=\"ti ti-layers-union text-2xl\" data-kid=\"30\"></i>\n                </div>\n                <h3 class=\"font-outfit font-bold text-lg\" data-kid=\"31\">AI Evaluation</h3>\n                <p class=\"text-sm text-white/50\" data-kid=\"32\">Systematic scoring across quality & safety.</p>\n              </div>\n              <div class=\"glass p-6 space-y-4\" data-kid=\"33\">\n                <div class=\"w-12 h-12 rounded-xl bg-cyan-600/20 flex items-center justify-center text-cyan-400\" data-kid=\"34\">\n                  <i class=\"ti ti-activity text-2xl\" data-kid=\"35\"></i>\n                </div>\n                <h3 class=\"font-outfit font-bold text-lg\" data-kid=\"36\">RLHF Ops</h3>\n                <p class=\"text-sm text-white/50\" data-kid=\"37\">High-fidelity preference data at scale.</p>\n              </div>\n              <div class=\"glass p-6 space-y-4 col-span-2\" data-kid=\"38\">\n                <video src=\"https://videos.pexels.com/video-files/29836207/12813476_640_360_30fps.mp4\" poster=\"https://images.pexels.com/videos/29836207/pexels-photo-29836207.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=630&w=1200\" autoplay muted loop playsinline class=\"w-full h-48 object-cover rounded-xl\" data-kid=\"39\"></video>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-24 bg-void-black relative\" data-kid=\"40\">\n      <div class=\"container mx-auto px-6\" data-kid=\"41\">\n        <div class=\"grid grid-cols-2 lg:grid-cols-4 gap-8\" data-kid=\"42\">\n          <div class=\"glass p-8 text-center space-y-2 group hover:border-cyan-400/50 transition-all\" data-kid=\"43\">\n            <div class=\"text-5xl font-outfit font-bold text-cyan-400 stat-value\" data-target=\"500\" data-kid=\"44\">0</div>\n            <div class=\"text-xs uppercase tracking-widest text-white/40 font-bold\" data-kid=\"45\">Projects Delivered</div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-2 group hover:border-violet-400/50 transition-all\" data-kid=\"46\">\n            <div class=\"text-5xl font-outfit font-bold text-violet-400 stat-value\" data-target=\"99\" data-kid=\"47\">0</div>\n            <div class=\"text-xs uppercase tracking-widest text-white/40 font-bold\" data-kid=\"48\">Accuracy rate %</div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-2 group hover:border-cyan-400/50 transition-all\" data-kid=\"49\">\n            <div class=\"text-5xl font-outfit font-bold text-cyan-400 stat-value\" data-target=\"50\" data-kid=\"50\">0</div>\n            <div class=\"text-xs uppercase tracking-widest text-white/40 font-bold\" data-kid=\"51\">Million Points</div>\n          </div>\n          <div class=\"glass p-8 text-center space-y-2 group hover:border-violet-400/50 transition-all\" data-kid=\"52\">\n            <div class=\"text-5xl font-outfit font-bold text-violet-400 stat-value\" data-target=\"24\" data-kid=\"53\">0</div>\n            <div class=\"text-xs uppercase tracking-widest text-white/40 font-bold\" data-kid=\"54\">Hour Turnaround</div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-12 overflow-hidden border-y border-white/5\" data-kid=\"55\">\n      <div class=\"diagonal-ticker bg-violet-600/10 py-6 whitespace-nowrap\" data-kid=\"56\">\n        <div class=\"marquee-content flex gap-12 text-2xl font-outfit font-bold uppercase italic tracking-tighter text-white/20\" data-kid=\"57\">\n          <span data-kid=\"58\">AI Evaluation • RLHF • Human Feedback • Data Annotation • Red Teaming • QA Systems • LLM Benchmarking • IAA Tracking • Gold Sets • Workflow Design • Safety Testing • Preference Data • </span>\n          <span data-kid=\"59\">AI Evaluation • RLHF • Human Feedback • Data Annotation • Red Teaming • QA Systems • LLM Benchmarking • IAA Tracking • Gold Sets • Workflow Design • Safety Testing • Preference Data • </span>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-void-black\" data-kid=\"60\">\n      <div class=\"container mx-auto px-6\" data-kid=\"61\">\n        <div class=\"flex flex-col lg:flex-row justify-between items-end mb-16 gap-8\" data-kid=\"62\">\n          <div class=\"max-w-2xl space-y-4\" data-kid=\"63\">\n            <h2 class=\"text-5xl lg:text-7xl font-outfit font-bold\" data-kid=\"64\">Services optimized for <span class=\"text-cyan-400\" data-kid=\"65\">scale.</span></h2>\n            <p class=\"text-white/60 text-lg leading-relaxed\" data-kid=\"66\">End-to-end data operations for teams building frontier models. From taxonomy design to production-scale evaluation.</p>\n          </div>\n          <a href=\"#\" class=\"text-cyan-400 font-bold hover:underline\" data-kid=\"67\">View All Services →</a>\n        </div>\n\n        <div class=\"grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6\" data-kid=\"68\">\n          <div class=\"glass p-8 md:col-span-2 lg:col-span-2 bg-gradient-to-br from-violet-600/20 to-transparent border-violet-500/30\" data-kid=\"69\">\n            <div class=\"h-full flex flex-col justify-between space-y-12\" data-kid=\"70\">\n              <i class=\"ti ti-layers-intersect text-5xl text-violet-400\" data-kid=\"71\"></i>\n              <div class=\"space-y-4\" data-kid=\"72\">\n                <h3 class=\"text-3xl font-outfit font-bold\" data-kid=\"73\">Human Feedback Ops</h3>\n                <p class=\"text-white/60\" data-kid=\"74\">Structured collection of human judgment signals to improve model behavior and safety. Optimized for alignment teams.</p>\n                <div class=\"flex gap-2\" data-kid=\"75\">\n                  <span class=\"px-3 py-1 rounded-full bg-violet-500/10 text-violet-300 text-xs font-bold\" data-kid=\"76\">Feedback Datasets</span>\n                  <span class=\"px-3 py-1 rounded-full bg-violet-500/10 text-violet-300 text-xs font-bold\" data-kid=\"77\">IAA Reports</span>\n                </div>\n              </div>\n            </div>\n          </div>\n          <div class=\"glass p-8 flex flex-col justify-between group hover:border-cyan-400/50 transition-all\" data-kid=\"78\">\n             <i class=\"ti ti-shield-check text-4xl text-cyan-400\" data-kid=\"79\"></i>\n             <div class=\"space-y-2 mt-12\" data-kid=\"80\">\n                <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"81\">Red Teaming</h3>\n                <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"82\">Adversarial testing to identify failure modes and jailbreaks.</p>\n             </div>\n          </div>\n          <div class=\"glass p-8 flex flex-col justify-between group hover:border-cyan-400/50 transition-all\" data-kid=\"83\">\n             <i class=\"ti ti-cpu text-4xl text-cyan-400\" data-kid=\"84\"></i>\n             <div class=\"space-y-2 mt-12\" data-kid=\"85\">\n                <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"86\">QA Framework</h3>\n                <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"87\">Multi-tier QA model ensuring enterprise-grade accuracy.</p>\n             </div>\n          </div>\n          <div class=\"glass p-8 flex flex-col justify-between group hover:border-cyan-400/50 transition-all\" data-kid=\"88\">\n             <i class=\"ti ti-activity text-4xl text-cyan-400\" data-kid=\"89\"></i>\n             <div class=\"space-y-2 mt-12\" data-kid=\"90\">\n                <h3 class=\"text-xl font-outfit font-bold\" data-kid=\"91\">LLM Benchmarking</h3>\n                <p class=\"text-sm text-white/50 leading-relaxed\" data-kid=\"92\">Comparative evaluation across tasks and safety criteria.</p>\n             </div>\n          </div>\n          <div class=\"glass p-8 md:col-span-2 lg:col-span-3 bg-gradient-to-br from-cyan-600/10 to-transparent border-cyan-500/20\" data-kid=\"93\">\n             <div class=\"flex flex-col md:flex-row gap-8 items-center\" data-kid=\"94\">\n                <div class=\"space-y-4 md:w-2/3\" data-kid=\"95\">\n                  <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"96\">Data Annotation Ops</h3>\n                  <p class=\"text-white/60\" data-kid=\"97\">High-accuracy labeling for image, video, and text across modalities. Built for teams with zero tolerance for noise.</p>\n                  <button class=\"text-cyan-400 font-bold text-sm\" data-kid=\"98\">Explore modality support →</button>\n                </div>\n                <div class=\"md:w-1/3 grid grid-cols-3 gap-2\" data-kid=\"99\">\n                   <div class=\"aspect-square glass flex items-center justify-center text-cyan-400\" data-kid=\"100\"><i class=\"ti ti-photo text-xl\" data-kid=\"101\"></i></div>\n                   <div class=\"aspect-square glass flex items-center justify-center text-cyan-400\" data-kid=\"102\"><i class=\"ti ti-video text-xl\" data-kid=\"103\"></i></div>\n                   <div class=\"aspect-square glass flex items-center justify-center text-cyan-400\" data-kid=\"104\"><i class=\"ti ti-microphone text-xl\" data-kid=\"105\"></i></div>\n                </div>\n             </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-[#080815] relative overflow-hidden\" data-kid=\"106\">\n      <div class=\"absolute top-0 right-0 w-96 h-96 bg-cyan-600/10 blur-[120px] rounded-full\" data-kid=\"107\"></div>\n      <div class=\"container mx-auto px-6\" data-kid=\"108\">\n        <div class=\"max-w-4xl mx-auto\" data-kid=\"109\">\n          <div class=\"text-center mb-20 space-y-4\" data-kid=\"110\">\n             <h2 class=\"text-5xl font-outfit font-bold\" data-kid=\"111\">The Pilot-First <span class=\"text-violet-400\" data-kid=\"112\">Journey.</span></h2>\n             <p class=\"text-white/50 max-w-lg mx-auto\" data-kid=\"113\">Zero risk. High impact. We validate our quality on your actual data before you commit to production scale.</p>\n          </div>\n\n          <div class=\"space-y-12 relative dot-line\" data-kid=\"114\">\n            <div class=\"relative pl-12 reveal-item\" style=\"--i: 0\" data-kid=\"115\">\n              <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full glass border-cyan-400 flex items-center justify-center z-10\" data-kid=\"116\">\n                <div class=\"w-2 h-2 rounded-full bg-cyan-400\" data-kid=\"117\"></div>\n              </div>\n              <div class=\"glass p-8 space-y-2\" data-kid=\"118\">\n                <span class=\"text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"119\">Step 01</span>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"120\">Discovery</h3>\n                <p class=\"text-white/60\" data-kid=\"121\">Understand your data, model, and quality requirements in a technical discovery call.</p>\n              </div>\n            </div>\n            <div class=\"relative pl-12 reveal-item\" style=\"--i: 1\" data-kid=\"122\">\n              <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full glass border-violet-400 flex items-center justify-center z-10\" data-kid=\"123\">\n                <div class=\"w-2 h-2 rounded-full bg-violet-400\" data-kid=\"124\"></div>\n              </div>\n              <div class=\"glass p-8 space-y-2 bg-gradient-to-r from-violet-600/10 to-transparent\" data-kid=\"125\">\n                <span class=\"text-xs font-bold text-violet-400 uppercase tracking-widest\" data-kid=\"126\">Step 02</span>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"127\">The Pilot</h3>\n                <p class=\"text-white/60\" data-kid=\"128\">Execute a free sample batch on your data with our full 3-tier QA process. No commitment.</p>\n              </div>\n            </div>\n            <div class=\"relative pl-12 reveal-item\" style=\"--i: 2\" data-kid=\"129\">\n              <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full glass border-cyan-400 flex items-center justify-center z-10\" data-kid=\"130\">\n                <div class=\"w-2 h-2 rounded-full bg-cyan-400\" data-kid=\"131\"></div>\n              </div>\n              <div class=\"glass p-8 space-y-2\" data-kid=\"132\">\n                <span class=\"text-xs font-bold text-cyan-400 uppercase tracking-widest\" data-kid=\"133\">Step 03</span>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"134\">Alignment</h3>\n                <p class=\"text-white/60\" data-kid=\"135\">Refine annotation guidelines based on edge cases found in the pilot batch.</p>\n              </div>\n            </div>\n            <div class=\"relative pl-12 reveal-item\" style=\"--i: 3\" data-kid=\"136\">\n              <div class=\"absolute left-0 top-0 w-8 h-8 rounded-full glass border-violet-400 flex items-center justify-center z-10\" data-kid=\"137\">\n                <div class=\"w-2 h-2 rounded-full bg-violet-400\" data-kid=\"138\"></div>\n              </div>\n              <div class=\"glass p-8 space-y-2 bg-gradient-to-r from-violet-600/10 to-transparent\" data-kid=\"139\">\n                <span class=\"text-xs font-bold text-violet-400 uppercase tracking-widest\" data-kid=\"140\">Step 04</span>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"141\">Production Scale</h3>\n                <p class=\"text-white/60\" data-kid=\"142\">Scale to full volume with established quality baselines and real-time reporting dashboards.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section id=\"qa-pin-section\" class=\"py-32 bg-void-black\" data-kid=\"143\">\n      <div class=\"container mx-auto px-6\" data-kid=\"144\">\n        <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20 items-center\" data-kid=\"145\">\n          <div class=\"space-y-12\" data-kid=\"146\">\n            <h2 class=\"text-6xl font-outfit font-bold leading-tight\" data-kid=\"147\">Zero-Noise <br data-kid=\"148\"><span class=\"text-cyan-400\" data-kid=\"149\">QA Architecture.</span></h2>\n            <div class=\"space-y-8\" data-kid=\"150\">\n              <div class=\"flex gap-6\" data-kid=\"151\">\n                <div class=\"w-12 h-12 rounded-xl glass flex items-center justify-center text-cyan-400 shrink-0\" data-kid=\"152\"><i class=\"ti ti-lock\" data-kid=\"153\"></i></div>\n                <div data-kid=\"154\">\n                  <h4 class=\"text-xl font-bold mb-1\" data-kid=\"155\">Founder-Led Delivery</h4>\n                  <p class=\"text-white/50 text-sm\" data-kid=\"156\">Strategic oversight on every project baseline.</p>\n                </div>\n              </div>\n              <div class=\"flex gap-6\" data-kid=\"157\">\n                <div class=\"w-12 h-12 rounded-xl glass flex items-center justify-center text-violet-400 shrink-0\" data-kid=\"158\"><i class=\"ti ti-activity\" data-kid=\"159\"></i></div>\n                <div data-kid=\"160\">\n                  <h4 class=\"text-xl font-bold mb-1\" data-kid=\"161\">IAA tracking</h4>\n                  <p class=\"text-white/50 text-sm\" data-kid=\"162\">Inter-annotator agreement metrics on every batch.</p>\n                </div>\n              </div>\n              <div class=\"flex gap-6\" data-kid=\"163\">\n                <div class=\"w-12 h-12 rounded-xl glass flex items-center justify-center text-cyan-400 shrink-0\" data-kid=\"164\"><i class=\"ti ti-layers-linked\" data-kid=\"165\"></i></div>\n                <div data-kid=\"166\">\n                  <h4 class=\"text-xl font-bold mb-1\" data-kid=\"167\">3-Tier Review</h4>\n                  <p class=\"text-white/50 text-sm\" data-kid=\"168\">Annotator → Senior Reviewer → Project Lead.</p>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"relative h-[600px] flex items-center justify-center qa-card-stack\" data-kid=\"169\">\n            <div class=\"absolute w-[400px] h-[500px] glass p-8 bg-cyan-900/10 border-cyan-500/30 z-30 qa-card\" id=\"qa-card-1\" data-kid=\"170\">\n              <div class=\"space-y-6\" data-kid=\"171\">\n                <div class=\"w-full h-40 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center italic text-white/20\" data-kid=\"172\">Audit Log Layer</div>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"173\">Tier 3: Audit</h3>\n                <p class=\"text-white/50\" data-kid=\"174\">Final project lead review ensuring cross-batch consistency and guideline fidelity.</p>\n              </div>\n            </div>\n            <div class=\"absolute w-[400px] h-[500px] glass p-8 bg-violet-900/10 border-violet-500/30 z-20 translate-x-8 -translate-y-8 qa-card\" id=\"qa-card-2\" data-kid=\"175\">\n              <div class=\"space-y-6\" data-kid=\"176\">\n                <div class=\"w-full h-40 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center italic text-white/20\" data-kid=\"177\">Consensus Layer</div>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"178\">Tier 2: Review</h3>\n                <p class=\"text-white/50\" data-kid=\"179\">Senior subject matter experts verifying edge-case interpretations and resolving conflicts.</p>\n              </div>\n            </div>\n            <div class=\"absolute w-[400px] h-[500px] glass p-8 bg-slate-900/10 border-white/10 z-10 translate-x-16 -translate-y-16 qa-card\" id=\"qa-card-3\" data-kid=\"180\">\n              <div class=\"space-y-6\" data-kid=\"181\">\n                <div class=\"w-full h-40 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center italic text-white/20\" data-kid=\"182\">Production Layer</div>\n                <h3 class=\"text-2xl font-outfit font-bold\" data-kid=\"183\">Tier 1: Annotation</h3>\n                <p class=\"text-white/50\" data-kid=\"184\">Core labeling execution following calibrated instructions and domain-specific rubrics.</p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"py-32 bg-[#050510] relative overflow-hidden\" data-kid=\"185\">\n      <div class=\"absolute inset-0 aurora opacity-30\" data-kid=\"186\"></div>\n      <div class=\"container mx-auto px-6 relative z-10 text-center\" data-kid=\"187\">\n        <h2 class=\"text-5xl font-outfit font-bold mb-20\" data-kid=\"188\">Enterprise <span class=\"text-cyan-400\" data-kid=\"189\">Security.</span></h2>\n        \n        <div class=\"relative h-[400px]\" data-kid=\"190\">\n          <div class=\"absolute top-10 left-[10%] glass px-8 py-4 rounded-full floating-island border-cyan-400/30 flex items-center gap-4 bg-void-black/80\" data-kid=\"191\">\n            <i class=\"ti ti-lock text-cyan-400 text-xl\" data-kid=\"192\"></i>\n            <span class=\"font-bold\" data-kid=\"193\">NDA-Enforced Teams</span>\n          </div>\n          <div class=\"absolute top-40 right-[15%] glass px-8 py-4 rounded-full floating-island border-violet-400/30 flex items-center gap-4 bg-void-black/80\" style=\"animation-delay: -2s\" data-kid=\"194\">\n            <i class=\"ti ti-shield-check text-violet-400 text-xl\" data-kid=\"195\"></i>\n            <span class=\"font-bold\" data-kid=\"196\">Project Isolation</span>\n          </div>\n          <div class=\"absolute bottom-10 left-[25%] glass px-8 py-4 rounded-full floating-island border-cyan-400/30 flex items-center gap-4 bg-void-black/80\" style=\"animation-delay: -4s\" data-kid=\"197\">\n            <i class=\"ti ti-activity text-cyan-400 text-xl\" data-kid=\"198\"></i>\n            <span class=\"font-bold\" data-kid=\"199\">Full Audit Trails</span>\n          </div>\n          <div class=\"absolute top-0 right-[40%] glass px-8 py-4 rounded-full floating-island border-violet-400/30 flex items-center gap-4 bg-void-black/80\" style=\"animation-delay: -1s\" data-kid=\"200\">\n            <i class=\"ti ti-key text-violet-400 text-xl\" data-kid=\"201\"></i>\n            <span class=\"font-bold\" data-kid=\"202\">RBAC Access Control</span>\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <section class=\"relative min-h-screen flex items-center justify-center bg-void-black overflow-hidden\" id=\"cta-section\" data-kid=\"203\">\n      <div id=\"peephole-mask\" class=\"absolute inset-0 bg-cyan-600 z-0 scale-0 rounded-full opacity-10 blur-[100px]\" data-kid=\"204\"></div>\n      \n      <div class=\"container mx-auto px-6 relative z-10 text-center space-y-12\" data-kid=\"205\">\n        <div class=\"space-y-4\" data-kid=\"206\">\n          <h2 class=\"text-6xl lg:text-9xl font-outfit font-bold tracking-tighter uppercase leading-[0.9]\" data-kid=\"207\">\n            Ready to <br data-kid=\"208\">Build <span class=\"text-cyan-400\" data-kid=\"209\">Better?</span>\n          </h2>\n          <p class=\"text-xl text-white/50 max-w-2xl mx-auto\" data-kid=\"210\">Join frontier AI teams scaling human intelligence operations with YUG AI.</p>\n        </div>\n        \n        <div class=\"flex flex-col md:flex-row items-center justify-center gap-6\" data-kid=\"211\">\n          <button class=\"btn-primary px-12 py-5 rounded-full font-bold text-xl group\" data-kid=\"212\">\n             Schedule Discovery Call\n             <i class=\"ti ti-arrow-right ml-2 group-hover:translate-x-1 transition-transform\" data-kid=\"213\"></i>\n          </button>\n          <div class=\"text-white/40 font-mono text-sm tracking-widest uppercase\" data-kid=\"214\">\n            hello@yugai.live\n          </div>\n        </div>\n      </div>\n    </section>\n\n    \n    <footer class=\"py-20 border-t border-white/5 bg-[#030308]\" data-kid=\"215\">\n      <div class=\"container mx-auto px-6\" data-kid=\"216\">\n        <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"217\">\n          <div class=\"col-span-2 space-y-6\" data-kid=\"218\">\n            <div class=\"flex items-center gap-2\" data-kid=\"219\">\n              <div class=\"w-8 h-8 rounded-lg bg-gradient-to-br from-cyan-400 to-violet-600\" data-kid=\"220\"></div>\n              <span class=\"font-outfit font-bold text-xl tracking-tight\" data-kid=\"221\">YUG AI</span>\n            </div>\n            <p class=\"text-white/40 max-w-sm leading-relaxed\" data-kid=\"222\">Precision human intelligence for modern AI teams. Built for safety, accuracy, and enterprise-scale operations.</p>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"223\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"224\">Services</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"225\">\n              <li data-kid=\"226\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"227\">AI Evaluation</a></li>\n              <li data-kid=\"228\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"229\">RLHF Ops</a></li>\n              <li data-kid=\"230\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"231\">Data Annotation</a></li>\n              <li data-kid=\"232\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"233\">Red Teaming</a></li>\n            </ul>\n          </div>\n          <div class=\"space-y-6\" data-kid=\"234\">\n            <h4 class=\"font-bold text-sm uppercase tracking-widest text-white/60\" data-kid=\"235\">Company</h4>\n            <ul class=\"space-y-4 text-sm text-white/40 font-medium\" data-kid=\"236\">\n              <li data-kid=\"237\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"238\">About</a></li>\n              <li data-kid=\"239\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"240\">Portfolio</a></li>\n              <li data-kid=\"241\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"242\">Contact</a></li>\n              <li data-kid=\"243\"><a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"244\">Privacy Policy</a></li>\n            </ul>\n          </div>\n        </div>\n        <div class=\"mt-20 pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs font-bold uppercase tracking-[0.2em] text-white/20\" data-kid=\"245\">\n          <span data-kid=\"246\">© 2026 YUG AI OPERATIONS</span>\n          <div class=\"flex gap-8\" data-kid=\"247\">\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"248\">Twitter</a>\n            <a href=\"#\" class=\"hover:text-cyan-400\" data-kid=\"249\">LinkedIn</a>\n          </div>\n        </div>\n      </div>\n    </footer>\n  </div>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"250\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"251\"></script>\n<script type=\"module\" data-kid=\"252\">\n  import { animate, inView, scroll } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n  import { animate as animeAnimate, stagger as animeStagger } from 'https://esm.sh/animejs@4'\n  import Lenis from \"https://esm.sh/lenis@1\"\n\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Initialize Smooth Scrolling\n  const lenis = new Lenis()\n  lenis.on('scroll', ScrollTrigger.update)\n  gsap.ticker.add((time) => {\n    lenis.raf(time * 1000)\n  })\n  gsap.ticker.lagSmoothing(0)\n\n  // Aurora Gradient Animation\n  animeAnimate('.aurora', {\n    backgroundPosition: ['0% 0%', '100% 50%', '0% 100%', '0% 0%'],\n    duration: 20000,\n    loop: true,\n    ease: 'linear'\n  });\n\n  // Floating Islands Loop\n  document.querySelectorAll('.floating-island').forEach((el, i) => {\n    animeAnimate(el, {\n      y: [-10, 10],\n      duration: 3000 + i * 500,\n      alternate: true,\n      loop: true,\n      ease: 'inOut(2)'\n    });\n  });\n\n  // Entrance Animations\n  gsap.from('.lg\\\\:col-span-7 > *', {\n    autoAlpha: 0,\n    y: 30,\n    duration: 1,\n    stagger: 0.1,\n    ease: 'power3.out'\n  });\n\n  gsap.from('.lg\\\\:col-span-5 .glass', {\n    autoAlpha: 0,\n    scale: 0.8,\n    duration: 1,\n    stagger: 0.2,\n    ease: 'back.out(1.7)',\n    delay: 0.5\n  });\n\n  // Stat Count-up\n  inView('.stat-value', ({ target }) => {\n    const end = parseInt(target.getAttribute('data-target'));\n    animate(0, end, {\n      duration: 2,\n      onUpdate: (v) => target.textContent = Math.round(v) + (end === 99 ? '%' : '+')\n    });\n  });\n\n  // Services Stagger\n  gsap.from('.services-grid .glass', {\n    scrollTrigger: {\n      trigger: '.services-grid',\n      start: 'top 80%'\n    },\n    autoAlpha: 0,\n    y: 40,\n    stagger: 0.1,\n    duration: 0.8\n  });\n\n  // Workflow Reveal\n  inView('.reveal-item', ({ target }) => {\n    gsap.from(target, {\n      autoAlpha: 0,\n      x: -30,\n      duration: 0.8,\n      ease: 'power2.out',\n      delay: target.style.getPropertyValue('--i') * 0.15\n    });\n  });\n\n  // QA Card Stack Scrub\n  const qaTl = gsap.timeline({\n    scrollTrigger: {\n      trigger: '#qa-pin-section',\n      start: 'top center',\n      end: 'bottom center',\n      scrub: 1\n    }\n  });\n\n  qaTl.to('#qa-card-1', { x: 0, y: 0, rotationY: 0, zIndex: 30, duration: 1 })\n      .to('#qa-card-2', { x: 20, y: -20, rotationY: -5, zIndex: 20, duration: 1 }, 0)\n      .to('#qa-card-3', { x: 40, y: -40, rotationY: -10, zIndex: 10, duration: 1 }, 0);\n\n  // CTA Peephole Mask Expansion\n  gsap.to('#peephole-mask', {\n    scrollTrigger: {\n      trigger: '#cta-section',\n      start: 'top bottom',\n      end: 'center center',\n      scrub: true\n    },\n    scale: 15,\n    opacity: 0.4\n  });\n\n  // Magnetic Button Effect\n  document.querySelectorAll('.btn-primary').forEach(btn => {\n    btn.addEventListener('mousemove', (e) => {\n      const rect = btn.getBoundingClientRect();\n      const x = e.clientX - rect.left - rect.width / 2;\n      const y = e.clientY - rect.top - rect.height / 2;\n      gsap.to(btn, {\n        x: x * 0.3,\n        y: y * 0.3,\n        duration: 0.4,\n        ease: 'power2.out'\n      });\n    });\n    btn.addEventListener('mouseleave', () => {\n      gsap.to(btn, {\n        x: 0,\n        y: 0,\n        duration: 0.6,\n        ease: 'elastic.out(1, 0.3)'\n      });\n    });\n  });\n\n</script>",
