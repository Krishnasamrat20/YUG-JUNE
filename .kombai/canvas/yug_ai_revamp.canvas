      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Anton&family=Space+Grotesk:wght@400;700&display=swap');\n\n  :root {\n    --acid-green: #CCFF00;\n    --pure-black: #000000;\n    --charcoal: #1A1A1A;\n  }\n\n  body {\n    background-color: var(--pure-black);\n    color: white;\n    font-family: 'Space Grotesk', sans-serif;\n    margin: 0;\n    padding: 0;\n    overflow-x: clip;\n  }\n\n  .font-anton { font-family: 'Anton', sans-serif; }\n  \n  .brutalist-border {\n    border: 3px solid var(--pure-black);\n  }\n  \n  .acid-bg {\n    background-color: var(--acid-green);\n    color: var(--pure-black);\n  }\n\n  .text-stroke {\n    -webkit-text-stroke: 2px var(--acid-green);\n    color: transparent;\n  }\n\n  .marquee-content {\n    display: flex;\n    white-space: nowrap;\n    animation: marquee 30s linear infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .terminal-window {\n    background: #0D0D0D;\n    border: 2px solid #333;\n    border-radius: 8px;\n    box-shadow: 0 20px 50px rgba(0,0,0,0.5);\n  }\n\n  .cursor {\n    display: inline-block;\n    width: 10px;\n    height: 20px;\n    background: var(--acid-green);\n    margin-left: 4px;\n    vertical-align: middle;\n  }\n\n  .char-wrap {\n    overflow: hidden;\n    display: inline-block;\n  }\n</style>\n\n<main class=\"w-full\" data-kid=\"1\">\n  \n  <section class=\"min-h-screen flex flex-col justify-end p-8 md:p-16 relative overflow-hidden acid-bg\" data-kid=\"2\">\n    <div class=\"absolute top-0 right-0 w-1/2 h-full opacity-30 grayscale contrast-150 mix-blend-multiply\" data-kid=\"3\">\n      <img src=\"https://images.unsplash.com/photo-1486551937199-baf066858de7?auto=format&w=1440&q=80&fit=crop\" class=\"w-full h-full object-cover\" loading=\"lazy\" decoding=\"async\" alt=\"Technical diagram\" data-kid=\"4\">\n    </div>\n    \n    <div class=\"relative z-10 max-w-7xl\" data-kid=\"5\">\n      <p class=\"text-xl md:text-2xl uppercase tracking-tighter mb-4 font-bold\" data-kid=\"6\">Human Intelligence for Better AI</p>\n      <h1 id=\"hero-title\" class=\"text-[12vw] leading-[0.85] font-anton uppercase mb-8\" data-kid=\"7\">\n        <span class=\"char-wrap\" data-kid=\"8\">HUMAN</span><br data-kid=\"9\">\n        <span class=\"char-wrap\" data-kid=\"10\">INTELLIGENCE</span>\n      </h1>\n      <div class=\"flex flex-wrap gap-4\" data-kid=\"11\">\n        <button class=\"bg-black text-white px-8 py-4 text-xl font-bold brutalist-border hover:bg-white hover:text-black transition-colors duration-300\" data-kid=\"12\">\n          GET STARTED\n        </button>\n        <button class=\"border-4 border-black px-8 py-4 text-xl font-bold hover:bg-black hover:text-white transition-colors duration-300\" data-kid=\"13\">\n          OUR SERVICES\n        </button>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-12 bg-black border-y-4 border-[#CCFF00] overflow-hidden\" data-kid=\"14\">\n    <div class=\"marquee-content font-anton text-[10vw] uppercase leading-none\" data-kid=\"15\">\n      <span class=\"px-8 text-[#CCFF00]\" data-kid=\"16\">YUG AI</span>\n      <span class=\"px-8 text-stroke\" data-kid=\"17\">DATA ANNOTATION</span>\n      <span class=\"px-8 text-[#CCFF00]\" data-kid=\"18\">RLHF</span>\n      <span class=\"px-8 text-stroke\" data-kid=\"19\">RED TEAMING</span>\n      <span class=\"px-8 text-[#CCFF00]\" data-kid=\"20\">YUG AI</span>\n      <span class=\"px-8 text-stroke\" data-kid=\"21\">DATA ANNOTATION</span>\n      <span class=\"px-8 text-[#CCFF00]\" data-kid=\"22\">RLHF</span>\n      <span class=\"px-8 text-stroke\" data-kid=\"23\">RED TEAMING</span>\n    </div>\n  </section>\n\n  \n  <section class=\"grid grid-cols-1 md:grid-cols-3 bg-black\" data-kid=\"24\">\n    <div class=\"p-12 border-b-4 md:border-b-0 md:border-r-4 border-[#CCFF00] flex flex-col items-center justify-center group hover:bg-[#CCFF00] transition-colors duration-500\" data-kid=\"25\">\n      <span class=\"text-6xl font-anton text-[#CCFF00] group-hover:text-black mb-2 stat-num\" data-target=\"1000000\" data-kid=\"26\">1M+</span>\n      <span class=\"text-xl uppercase font-bold text-white group-hover:text-black\" data-kid=\"27\">Data Points</span>\n    </div>\n    <div class=\"p-12 border-b-4 md:border-b-0 md:border-r-4 border-[#CCFF00] flex flex-col items-center justify-center group hover:bg-[#CCFF00] transition-colors duration-500\" data-kid=\"28\">\n      <span class=\"text-6xl font-anton text-[#CCFF00] group-hover:text-black mb-2 stat-num\" data-target=\"500\" data-kid=\"29\">500+</span>\n      <span class=\"text-xl uppercase font-bold text-white group-hover:text-black\" data-kid=\"30\">Annotators</span>\n    </div>\n    <div class=\"p-12 flex flex-col items-center justify-center group hover:bg-[#CCFF00] transition-colors duration-500\" data-kid=\"31\">\n      <span class=\"text-6xl font-anton text-[#CCFF00] group-hover:text-black mb-2 stat-num\" data-target=\"99\" data-kid=\"32\">99%</span>\n      <span class=\"text-xl uppercase font-bold text-white group-hover:text-black\" data-kid=\"33\">Accuracy</span>\n    </div>\n  </section>\n\n  \n  <section class=\"p-8 md:p-16 bg-black\" data-kid=\"34\">\n    <h2 class=\"text-6xl font-anton uppercase mb-12 text-[#CCFF00]\" data-kid=\"35\">Our Capabilities</h2>\n    <div class=\"grid grid-cols-1 md:grid-cols-6 grid-rows-4 gap-4 h-[1200px] md:h-[800px]\" data-kid=\"36\">\n      \n      <div class=\"md:col-span-4 md:row-span-2 bg-[#1A1A1A] p-8 border-4 border-[#CCFF00] relative overflow-hidden group hover:bg-[#CCFF00] transition-all duration-500\" data-kid=\"37\">\n        <div class=\"relative z-10\" data-kid=\"38\">\n          <h3 class=\"text-4xl font-anton uppercase mb-4 group-hover:text-black\" data-kid=\"39\">AI Evaluation</h3>\n          <p class=\"text-lg opacity-70 group-hover:text-black group-hover:opacity-100 max-w-md\" data-kid=\"40\">Comprehensive testing and benchmarking for large language models and computer vision systems.</p>\n        </div>\n        <img src=\"https://images.unsplash.com/photo-1545987796-200677ee1011?auto=format&w=800&q=80&fit=crop\" class=\"absolute bottom-0 right-0 w-1/2 opacity-20 group-hover:opacity-40 transition-opacity grayscale\" alt=\"Tech\" data-kid=\"41\">\n      </div>\n      \n      \n      <div class=\"md:col-span-2 md:row-span-1 bg-[#CCFF00] p-8 border-4 border-black flex flex-col justify-between group hover:bg-black transition-all duration-500\" data-kid=\"42\">\n        <h3 class=\"text-3xl font-anton uppercase text-black group-hover:text-[#CCFF00]\" data-kid=\"43\">RLHF</h3>\n        <p class=\"text-black group-hover:text-white font-bold\" data-kid=\"44\">Reinforcement Learning from Human Feedback.</p>\n      </div>\n\n      \n      <div class=\"md:col-span-2 md:row-span-2 bg-[#1A1A1A] p-8 border-4 border-[#CCFF00] flex flex-col justify-end group hover:bg-[#CCFF00] transition-all duration-500\" data-kid=\"45\">\n        <h3 class=\"text-3xl font-anton uppercase mb-2 group-hover:text-black\" data-kid=\"46\">Data Annotation</h3>\n        <p class=\"group-hover:text-black\" data-kid=\"47\">High-precision labeling for text, image, and video data.</p>\n      </div>\n\n      \n      <div class=\"md:col-span-2 md:row-span-1 bg-[#1A1A1A] p-8 border-4 border-[#CCFF00] hover:bg-[#CCFF00] transition-all duration-500 group\" data-kid=\"48\">\n        <h3 class=\"text-2xl font-anton uppercase group-hover:text-black\" data-kid=\"49\">Collection</h3>\n        <p class=\"text-sm group-hover:text-black\" data-kid=\"50\">Ethical, large-scale dataset acquisition.</p>\n      </div>\n\n      \n      <div class=\"md:col-span-2 md:row-span-2 bg-black p-8 border-4 border-[#CCFF00] relative group overflow-hidden\" data-kid=\"51\">\n        <div class=\"absolute inset-0 bg-[#CCFF00] translate-y-full group-hover:translate-y-0 transition-transform duration-500\" data-kid=\"52\"></div>\n        <div class=\"relative z-10\" data-kid=\"53\">\n          <h3 class=\"text-3xl font-anton uppercase mb-4 group-hover:text-black\" data-kid=\"54\">Red Teaming</h3>\n          <p class=\"group-hover:text-black\" data-kid=\"55\">Adversarial testing to ensure AI safety and robustness.</p>\n        </div>\n      </div>\n\n      \n      <div class=\"md:col-span-2 md:row-span-1 border-4 border-[#CCFF00] p-8 flex items-center justify-center hover:bg-[#CCFF00] group transition-all duration-500\" data-kid=\"56\">\n        <h3 class=\"text-2xl font-anton uppercase text-[#CCFF00] group-hover:text-black\" data-kid=\"57\">AI Development</h3>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"p-8 md:p-16 bg-[#1A1A1A]\" data-kid=\"58\">\n    <div class=\"max-w-4xl mx-auto\" data-kid=\"59\">\n      <div class=\"terminal-window overflow-hidden\" data-kid=\"60\">\n        <div class=\"bg-[#222] p-3 flex gap-2 border-b border-[#333]\" data-kid=\"61\">\n          <div class=\"w-3 h-3 rounded-full bg-[#FF5F56]\" data-kid=\"62\"></div>\n          <div class=\"w-3 h-3 rounded-full bg-[#FFBD2E]\" data-kid=\"63\"></div>\n          <div class=\"w-3 h-3 rounded-full bg-[#27C93F]\" data-kid=\"64\"></div>\n          <div class=\"ml-4 text-xs font-mono opacity-50 uppercase tracking-widest\" data-kid=\"65\">security_protocol.sh</div>\n        </div>\n        <div class=\"p-8 font-mono text-lg text-[#CCFF00] leading-relaxed\" data-kid=\"66\">\n          <div id=\"terminal-text\" data-kid=\"67\"></div>\n          <span class=\"cursor\" data-kid=\"68\"></span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 px-8 text-center bg-[#CCFF00]\" data-kid=\"69\">\n    <h2 class=\"text-7xl md:text-[10vw] font-anton text-black uppercase leading-none mb-12\" data-kid=\"70\">REVOLUTIONIZE YOUR AI</h2>\n    <button class=\"bg-black text-[#CCFF00] text-3xl md:text-5xl font-anton uppercase px-16 py-8 border-8 border-black hover:bg-transparent hover:text-black transition-all duration-500\" data-kid=\"71\">\n      Build with YUG AI\n    </button>\n  </section>\n\n  \n  <footer class=\"p-16 bg-black border-t-8 border-[#CCFF00]\" data-kid=\"72\">\n    <div class=\"grid grid-cols-1 md:grid-cols-4 gap-12\" data-kid=\"73\">\n      <div class=\"md:col-span-2\" data-kid=\"74\">\n        <span class=\"text-5xl font-anton text-[#CCFF00]\" data-kid=\"75\">YUG AI</span>\n        <p class=\"mt-8 text-xl max-w-sm opacity-60\" data-kid=\"76\">Pioneering the future of artificial intelligence through elite human collaboration.</p>\n      </div>\n      <div data-kid=\"77\">\n        <h4 class=\"font-anton text-2xl uppercase mb-6 text-[#CCFF00]\" data-kid=\"78\">Navigation</h4>\n        <ul class=\"space-y-4 text-lg font-bold uppercase\" data-kid=\"79\">\n          <li data-kid=\"80\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"81\">About</a></li>\n          <li data-kid=\"82\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"83\">Services</a></li>\n          <li data-kid=\"84\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"85\">Portfolio</a></li>\n          <li data-kid=\"86\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"87\">Contact</a></li>\n        </ul>\n      </div>\n      <div data-kid=\"88\">\n        <h4 class=\"font-anton text-2xl uppercase mb-6 text-[#CCFF00]\" data-kid=\"89\">Connect</h4>\n        <ul class=\"space-y-4 text-lg font-bold uppercase\" data-kid=\"90\">\n          <li data-kid=\"91\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"92\">LinkedIn</a></li>\n          <li data-kid=\"93\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"94\">Twitter</a></li>\n          <li data-kid=\"95\"><a href=\"#\" class=\"hover:text-[#CCFF00]\" data-kid=\"96\">Instagram</a></li>\n        </ul>\n      </div>\n    </div>\n    <div class=\"mt-24 pt-8 border-t-2 border-[#1A1A1A] flex flex-col md:flex-row justify-between items-center gap-4\" data-kid=\"97\">\n      <p class=\"opacity-40 uppercase font-bold tracking-widest text-xs\" data-kid=\"98\">© 2024 YUG AI. All rights reserved.</p>\n      <p class=\"opacity-40 uppercase font-bold tracking-widest text-xs\" data-kid=\"99\">Based in New Delhi, India</p>\n    </div>\n  </footer>\n</main>\n\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"100\"></script>\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/ScrollTrigger.min.js\" data-kid=\"101\"></script>\n<script type=\"module\" data-kid=\"102\">\n  import { animate, stagger } from 'https://esm.sh/animejs@4';\n\n  // GSAP ScrollTrigger\n  gsap.registerPlugin(ScrollTrigger);\n\n  // Hero Text Lift\n  const heroTitle = document.querySelector('#hero-title');\n  const words = heroTitle.innerHTML.split('<br>');\n  heroTitle.innerHTML = words.map(word => {\n    return `<div class=\"char-wrap\">${word.trim().split('').map(char => `<span class=\"hero-char inline-block\">${char === ' ' ? '&nbsp;' : char}</span>`).join('')}</div>`;\n  }).join('<br>');\n\n  animate('.hero-char', {\n    y: ['110%', '0%'],\n    opacity: [0, 1],\n    delay: stagger(30, {start: 500}),\n    duration: 1000,\n    easing: 'easeOutExpo'\n  });\n\n  // Stats Count Up\n  document.querySelectorAll('.stat-num').forEach(stat => {\n    ScrollTrigger.create({\n      trigger: stat,\n      start: 'top 90%',\n      onEnter: () => {\n        const target = parseInt(stat.getAttribute('data-target'));\n        const obj = { val: 0 };\n        gsap.to(obj, {\n          val: target,\n          duration: 2,\n          ease: 'power3.out',\n          onUpdate: () => {\n            if (target > 1000) {\n              stat.textContent = Math.floor(obj.val / 100000) / 10 + 'M+';\n              if (target < 1000000) stat.textContent = Math.floor(obj.val) + '+';\n            } else {\n              stat.textContent = Math.floor(obj.val) + (stat.textContent.includes('%') ? '%' : '+');\n            }\n          }\n        });\n      }\n    });\n  });\n\n  // Terminal Typewriter\n  const securityInfo = [\n    '> Initializing security_protocol...',\n    '> Scanning vulnerability surface...',\n    '> SOC2 Type II compliance: ACTIVE',\n    '> GDPR Data Privacy: VERIFIED',\n    '> Military Grade Encryption: ENABLED',\n    '> All systems operational.',\n    '> YUG AI: Protecting your future.'\n  ];\n\n  let currentLine = 0;\n  const terminalText = document.querySelector('#terminal-text');\n\n  function typeLine() {\n    if (currentLine < securityInfo.length) {\n      const line = document.createElement('div');\n      line.className = 'mb-2';\n      terminalText.appendChild(line);\n      \n      const chars = securityInfo[currentLine].split('');\n      animate(line, {\n        opacity: [0, 1],\n        duration: 1\n      });\n\n      let charIdx = 0;\n      const typeInterval = setInterval(() => {\n        if (charIdx < chars.length) {\n          line.textContent += chars[charIdx];\n          charIdx++;\n        } else {\n          clearInterval(typeInterval);\n          currentLine++;\n          setTimeout(typeLine, 400);\n        }\n      }, 30);\n    }\n  }\n\n  ScrollTrigger.create({\n    trigger: '.terminal-window',\n    start: 'top 80%',\n    onEnter: () => typeLine()\n  });\n\n  // Cursor Blink\n  animate('.cursor', {\n    opacity: [0, 1],\n    duration: 500,\n    direction: 'alternate',\n    loop: true,\n    easing: 'steps(2)'\n  });\n\n  // Batch reveal service cards\n  gsap.from('.grid > div', {\n    scrollTrigger: {\n      trigger: '.grid',\n      start: 'top 70%'\n    },\n    opacity: 0,\n    y: 50,\n    scale: 0.9,\n    stagger: 0.1,\n    duration: 0.8,\n    ease: 'back.out(1.7)'\n  });\n</script>",
